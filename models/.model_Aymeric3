# 4.  DOMAIN ADAPTER  (robust scaling + distribution alignment)
# ─────────────────────────────────────────────────────────────────────────────

class DomainAdapter:
    """
    Aligns a feature matrix to a reference distribution using:
      - Median / IQR robust scaling (handles fat tails)
      - Winsorisation at 2nd/98th percentile
      - Optional rank-based Gaussianisation (Gaussian CDF of empirical rank)
    """

    def __init__(self, gaussianise: bool = True):
        self.gaussianise = gaussianise
        self._median: np.ndarray | None = None
        self._iqr   : np.ndarray | None = None
        self._lo    : np.ndarray | None = None
        self._hi    : np.ndarray | None = None

    def fit(self, X: np.ndarray) -> "DomainAdapter":
        self._median = np.median(X, axis=0)
        self._lo     = np.percentile(X, 2,  axis=0)
        self._hi     = np.percentile(X, 98, axis=0)
        q25          = np.percentile(X, 25, axis=0)
        q75          = np.percentile(X, 75, axis=0)
        self._iqr    = np.maximum(q75 - q25, 1e-8)
        return self

    def transform(self, X: np.ndarray) -> np.ndarray:
        X = np.clip(X, self._lo, self._hi)
        X = (X - self._median) / self._iqr
        if self.gaussianise:
            # rank-based: map each feature to Gaussian via empirical CDF
            from scipy.special import ndtri          # noqa
            n = X.shape[0]
            for j in range(X.shape[1]):
                ranks = np.argsort(np.argsort(X[:, j])).astype(float)
                p     = (ranks + 0.5) / n
                p     = np.clip(p, 0.001, 0.999)
                try:
                    X[:, j] = ndtri(p)
                except Exception:
                    pass   # scipy not available → skip
        return X

    def fit_transform(self, X: np.ndarray) -> np.ndarray:
        return self.fit(X).transform(X)


def _gaussianise_fallback(X: np.ndarray) -> np.ndarray:
    """Rank-based Gaussianisation without scipy."""
    n = X.shape[0]
    out = X.copy()
    for j in range(X.shape[1]):
        ranks = np.argsort(np.argsort(X[:, j])).astype(float)
        p     = np.clip((ranks + 0.5) / n, 0.001, 0.999)
        # Box-Muller approximation via logit
        out[:, j] = np.log(p / (1 - p)) * 0.5887   # ≈ N(0,1) scale
    return out


class SimpleDomainAdapter:
    """Lightweight version without scipy."""

    def __init__(self):
        self._median: np.ndarray | None = None
        self._iqr   : np.ndarray | None = None
        self._lo    : np.ndarray | None = None
        self._hi    : np.ndarray | None = None

    def fit(self, X: np.ndarray) -> "SimpleDomainAdapter":
        self._median = np.median(X, axis=0)
        self._lo     = np.percentile(X, 2,  axis=0)
        self._hi     = np.percentile(X, 98, axis=0)
        q25          = np.percentile(X, 25, axis=0)
        q75          = np.percentile(X, 75, axis=0)
        self._iqr    = np.maximum(q75 - q25, 1e-8)
        return self

    def transform(self, X: np.ndarray) -> np.ndarray:
        X = np.clip(X, self._lo, self._hi)
        return (X - self._median) / self._iqr

    def fit_transform(self, X: np.ndarray) -> np.ndarray:
        return self.fit(X).transform(X)



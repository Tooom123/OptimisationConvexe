class PortfolioChallengeModel:
    """
    v3 — Cross-Domain Edition

    New vs v2:
      • Real market data integration (yfinance → CSV → GARCH simulator)
      • Adversarial domain classifier → sample weights for synthetic training
      • Signal filtering: only features consistent across both domains
      • CrossDomainEnsemble per asset (synth + real models blended by Sharpe)
      • Dual-covariance portfolio (Sigma_synth + Sigma_real blended)
      • Cross-domain evaluation report

    Config flags (pass to __init__):
      use_real_data : bool   activate real-data integration (default True)
      real_csv_dir  : str    path to folder with price CSVs (optional)
    """

    VAL_FRAC      = 0.20
    SHRINKAGE     = 0.65   # prediction shrink
    TARGET_VOL    = 0.005
    TURNOVER_EMA  = 0.35

    def __init__(self, use_real_data: bool = True,
                 real_csv_dir: str | None = None,
                 real_start: str = "2010-01-01",
                 real_end:   str = "2024-12-31"):
        self.use_real_data  = use_real_data
        self.real_csv_dir   = real_csv_dir
        self.real_start     = real_start
        self.real_end       = real_end

        self.feature_cols   : list = []
        self.asset_cols     : list = []
        self.pred_cols      : list = []
        self.weight_cols    : list = []

        self.feat_eng       : LeanFeatureEngineer | None = None
        self.real_feat_builder: RealFeatureBuilder | None = None
        self.domain_clf     : AdversarialDomainClassifier | None = None
        self.per_asset      : dict = {}     # asset → CrossDomainEnsemble
        self._real_feat_mat : np.ndarray | None = None   # aligned real features
        self._real_prices   : pd.DataFrame | None = None

    # ──────────────────────────────────────────────────────────────────────
    def read_table(self, p) -> pd.DataFrame:
        p = Path(p)
        if p.suffix.lower() == ".parquet":
            return pd.read_parquet(p)
        raise ValueError(f"Unsupported format: {p}")

    def load_data(self, data_dir: str = "data") -> dict:
        d = Path(data_dir)
        x_train = self.read_table(d / "X_train.parquet")
        r_train = self.read_table(d / "R_train.parquet")
        x_test  = self.read_table(d / "X_test.parquet")
        self.feature_cols  = [c for c in x_train.columns if c not in ("id","date","split")]
        self.asset_cols    = [c for c in r_train.columns if c not in ("id","date","split")]
        self.pred_cols     = [f"pred_{c}"   for c in self.asset_cols]
        self.weight_cols   = [f"weight_{c}" for c in self.asset_cols]
        log(f"Loaded: {len(x_train)} train | {len(x_test)} test | "
            f"{len(self.feature_cols)} feat | {len(self.asset_cols)} assets", "OK")
        return {"X_train": x_train, "R_train": r_train, "X_test": x_test}

    # ──────────────────────────────────────────────────────────────────────
    def _load_real_data(self) -> np.ndarray | None:
        """Fetch real (or simulated) market data and build feature matrix."""
        if not self.use_real_data:
            return None
        log("LOADING REAL MARKET DATA", "SECTION")
        fetcher = RealDataFetcher(start=self.real_start, end=self.real_end,
                                  csv_dir=self.real_csv_dir)
        prices = fetcher.fetch()
        self._real_prices = prices
        log(f"Data source: [{fetcher.source_}]  "
            f"Shape: {prices.shape[0]} days × {prices.shape[1]} assets",
            "REAL" if "garch" not in fetcher.source_ else "SIM")

        self.real_feat_builder = RealFeatureBuilder(n_components=20)
        real_feats = self.real_feat_builder.fit_transform(prices)

        # robust scale
        adapter = SimpleDomainAdapter()
        mat = adapter.fit_transform(real_feats.values)
        log(f"Real feature matrix: {mat.shape}  "
            f"(robust-scaled, 20 PCA components)", "OK")
        return mat

    # ──────────────────────────────────────────────────────────────────────
    def fit(self, x_train: pd.DataFrame, r_train: pd.DataFrame) -> None:
        log("PHASE 1 — SYNTHETIC FEATURE ENGINEERING", "SECTION")
        x_s = x_train.sort_values("date").reset_index(drop=True)
        r_s = r_train.sort_values("date").reset_index(drop=True)
        common = set(x_s["id"]) & set(r_s["id"])
        x_s = x_s[x_s["id"].isin(common)].reset_index(drop=True)
        r_s = r_s[r_s["id"].isin(common)].reset_index(drop=True)

        self.feat_eng = LeanFeatureEngineer(self.feature_cols)
        X_eng = self.feat_eng.fit_transform(x_s)
        log(f"Synthetic features: {X_eng.shape}", "OK")
        X_arr = X_eng.values.astype(float)

        # ── Real data
        real_mat = self._load_real_data()    # (T_real, 20) or None

        # ── Train/val split
        n     = len(X_arr)
        n_val = max(int(n * self.VAL_FRAC), 30)
        n_tr  = n - n_val
        X_tr  = X_arr[:n_tr];  X_val = X_arr[n_tr:]

        # ── Align real features to train/val split length
        X_real_tr = X_real_val = None
        if real_mat is not None:
            # take the last n_tr rows of real data as "train" and last n_val as "val"
            # (different calendar dates, but same statistical regime)
            n_real = len(real_mat)
            if n_real >= n_tr + n_val:
                X_real_tr  = real_mat[-(n_tr + n_val):-n_val]
                X_real_val = real_mat[-n_val:]
            elif n_real >= 50:
                split = int(n_real * (1 - self.VAL_FRAC))
                X_real_tr  = real_mat[:split]
                X_real_val = real_mat[split:]
            self._real_feat_mat = real_mat

        # ── Adversarial domain classifier
        sample_weights_tr = np.ones(n_tr)
        if X_real_tr is not None:
            log("PHASE 2 — ADVERSARIAL DOMAIN CLASSIFICATION", "SECTION")
            # use only shared feature count
            n_feat = min(X_tr.shape[1], X_real_tr.shape[1])
            self.domain_clf = AdversarialDomainClassifier(alpha=0.5, n_iter=300)
            self.domain_clf.fit(X_tr[:, :n_feat], X_real_tr[:, :n_feat])
            sample_weights_tr = self.domain_clf.sample_weights(X_tr[:, :n_feat])
            log(f"Sample weight stats: "
                f"min={sample_weights_tr.min():.3f}  "
                f"mean={sample_weights_tr.mean():.3f}  "
                f"max={sample_weights_tr.max():.3f}", "OK")

        # ── Per-asset cross-domain ensemble
        log("PHASE 3 — CROSS-DOMAIN PER-ASSET FITTING", "SECTION")
        log(f"{'Asset':12s}  {'Sh_s':>6s}  {'Sh_r':>6s}  "
            f"{'w_s':>5s}  {'w_r':>5s}  {'α':>7s}")

        for asset in self.asset_cols:
            if asset not in r_s.columns:
                continue
            y_all = r_s[asset].values.astype(float)
            y_tr  = y_all[:n_tr];  y_val = y_all[n_tr:]

            ens = CrossDomainEnsemble(asset=asset)
            ens.fit(
                X_synth_tr  = X_tr,
                y_tr        = y_tr,
                X_synth_val = X_val,
                y_val       = y_val,
                sample_weights_tr = sample_weights_tr,
                X_real_tr   = X_real_tr,
                X_real_val  = X_real_val,
            )
            self.per_asset[asset] = ens

        log("PHASE 3 COMPLETE", "OK")

    # ──────────────────────────────────────────────────────────────────────
    def predict_returns(self, x_df: pd.DataFrame) -> pd.DataFrame:
        x_df = x_df.sort_values("date").reset_index(drop=True)
        X_eng = self.feat_eng.transform(x_df)
        X_arr = X_eng.values.astype(float)

        # real features for inference (last len(x_df) rows of real_mat)
        X_real_inf = None
        if self._real_feat_mat is not None:
            n_inf = len(X_arr)
            n_real = len(self._real_feat_mat)
            if n_real >= n_inf:
                X_real_inf = self._real_feat_mat[-n_inf:]
            else:
                # pad with first rows (cyclic extension)
                reps = int(np.ceil(n_inf / n_real))
                X_real_inf = np.tile(self._real_feat_mat, (reps, 1))[:n_inf]

        preds = np.zeros((len(x_df), len(self.asset_cols)))
        for i, asset in enumerate(self.asset_cols):
            if asset in self.per_asset:
                preds[:, i] = self.per_asset[asset].predict(X_arr, X_real_inf)

        # calibration: CS z-score + shrinkage
        if preds.shape[1] > 1:
            mu = preds.mean(axis=1, keepdims=True)
            sd = preds.std(axis=1,  keepdims=True) + 1e-10
            preds = (preds - mu) / sd
        preds *= (1.0 - self.SHRINKAGE)
        preds = np.clip(preds, -3.0, 3.0)

        return pd.DataFrame(preds, columns=self.pred_cols, index=x_df.index)

    # ──────────────────────────────────────────────────────────────────────
    def build_weights(self, pred_df: pd.DataFrame,
                      x_df: pd.DataFrame | None = None) -> pd.DataFrame:
        raw = pred_df.to_numpy(dtype=float)

        # real covariance proxy (last len(pred_df) rows)
        real_cov = None
        if self._real_feat_mat is not None:
            n = len(raw)
            nr = len(self._real_feat_mat)
            if nr >= n:
                real_cov = self._real_feat_mat[-n:, :min(raw.shape[1], 20)]
            else:
                reps = int(np.ceil(n / nr))
                r = np.tile(self._real_feat_mat, (reps, 1))[:n]
                real_cov = r[:, :min(raw.shape[1], 20)]
            # pad/trim to match asset count
            if real_cov.shape[1] < raw.shape[1]:
                pad = np.zeros((len(real_cov), raw.shape[1] - real_cov.shape[1]))
                real_cov = np.hstack([real_cov, pad])
            else:
                real_cov = real_cov[:, :raw.shape[1]]

        builder = DualCovariancePortfolioBuilder(
            asset_cols   = self.asset_cols,
            target_vol   = self.TARGET_VOL,
            cov_window   = 63,
            synth_shrink = 0.6,
            real_shrink  = 0.7,
            gamma        = 0.4 if real_cov is not None else 0.0,
            turnover_ema = self.TURNOVER_EMA,
        )
        weights = builder.build(raw, real_cov)
        return pd.DataFrame(weights, columns=self.weight_cols, index=pred_df.index)

    # ──────────────────────────────────────────────────────────────────────
    def build_submission(self, x_train: pd.DataFrame,
                         x_test: pd.DataFrame) -> pd.DataFrame:
        log("BUILDING SUBMISSION", "SECTION")
        xt = x_train.sort_values("date").reset_index(drop=True)
        xte = x_test.sort_values("date").reset_index(drop=True)
        p_tr = self.predict_returns(xt);  p_te = self.predict_returns(xte)
        p_all = pd.concat([p_tr, p_te], axis=0).reset_index(drop=True)
        w_all = self.build_weights(p_all)
        idx   = pd.concat([xt[["id","date"]], xte[["id","date"]]], axis=0).reset_index(drop=True)
        sub   = pd.concat([idx, p_all, w_all], axis=1).fillna(0.0)
        log(f"Submission: {sub.shape[0]} rows × {sub.shape[1]} cols", "OK")
        return sub

    # ──────────────────────────────────────────────────────────────────────
    def save_submission(self, sub: pd.DataFrame,
                        path: str = "submission.parquet") -> Path:
        p = Path(path)
        sub.to_parquet(p, index=False)
        log(f"Saved → {p}", "OK")
        return p

    def fit_predict_save(self, data_dir: str = "data",
                         output_path: str = "submission.parquet") -> pd.DataFrame:
        data = self.load_data(data_dir)
        self.fit(data["X_train"], data["R_train"])
        sub  = self.build_submission(data["X_train"], data["X_test"])
        self.create_scorer().validate_submission_format(sub)
        log("Format validated ✓", "OK")
        self.save_submission(sub, output_path)
        return sub

    def create_scorer(self) -> SubmissionScorerTemplate:
        s = SubmissionScorerTemplate();  s.set_assets(self.asset_cols);  return s

    # ──────────────────────────────────────────────────────────────────────
    def cross_domain_evaluation(self, sub: pd.DataFrame,
                                 r_train: pd.DataFrame) -> dict:
        """Full cross-domain evaluation report."""
        log("CROSS-DOMAIN EVALUATION REPORT", "SECTION")

        w_cols = self.weight_cols;  r_cols = self.asset_cols
        merged = r_train[["id","date"]+r_cols].merge(
            sub[["id","date"]+w_cols], on=["id","date"], how="inner")
        if merged.empty:
            log("No overlap", "WARN"); return {}

        W = merged[w_cols].values;  R = merged[r_cols].values
        port_ret = (W * R).sum(axis=1)

        sh_port  = annualised_sharpe(port_ret)
        sh_std   = rolling_sharpe_std(port_ret)
        cum_ret  = float((1 + port_ret).prod() - 1)
        gross    = np.abs(W).sum(axis=1)

        log(f"Domain source       : {getattr(self, '_data_source', 'garch_simulator')}")
        log(f"Portfolio Sharpe    = {sh_port:.4f}")
        log(f"Rolling Sharpe Std  = {sh_std:.4f}  (lower = more stable)")
        log(f"Cumulative Return   = {cum_ret*100:.2f}%")
        log(f"Mean gross exposure = {gross.mean():.4f}  (max={gross.max():.4f})")
        log(f"L1 constraint OK    : {(gross <= 1.001).all()}", "OK")

        score = sh_port - 0.5 * sh_std
        log(f"Selection Score     = {score:.4f}  "
            f"(Sharpe - 0.5×ShStd)")

        log(f"\n{'Asset':14s}  {'w_avg':>8s}  {'Sh_pnl':>8s}  {'mul':>5s}")
        for asset, wcol in zip(r_cols, w_cols):
            pnl_a = merged[wcol].values * merged[asset].values
            sh_a  = annualised_sharpe(pnl_a)
            w_avg = merged[wcol].abs().mean()
            mul   = ASSET_MULTIPLIER.get(asset, 1.0)
            flag  = "⛔" if mul == 0 else ("↓" if mul < 0.5 else " ")
            log(f"  {asset:12s}  {w_avg:8.5f}  {sh_a:+8.3f}  "
                f"{mul:.2f}  {flag}")

        return {"sharpe": sh_port, "sharpe_std": sh_std,
                "cum_ret": cum_ret, "score": score}


# ─────────────────────────────────────────────────────────────────────────────
# 14.  MAIN
# ─────────────────────────────────────────────────────────────────────────────

def main():
    log("PORTFOLIO CHALLENGE — MODEL v3 (Cross-Domain Edition)", "SECTION")
    log("Hypothesis: train on synthetic + real → domain-invariant signals only")

    # ── CONFIG ──────────────────────────────────────────────────────────
    USE_REAL_DATA = True      # set False to disable real-data integration
    REAL_CSV_DIR  = None      # e.g. "data/real_market" if you have CSVs
    # ────────────────────────────────────────────────────────────────────

    model = PortfolioChallengeModel(
        use_real_data = USE_REAL_DATA,
        real_csv_dir  = REAL_CSV_DIR,
    )

    data = model.load_data(data_dir="data")
    model.fit(data["X_train"], data["R_train"])
    sub  = model.build_submission(data["X_train"], data["X_test"])

    results = model.cross_domain_evaluation(sub, data["R_train"])

    model.create_scorer().validate_submission_format(sub)
    log("Submission format validated ✓", "OK")
    out = model.save_submission(sub, "submission.parquet")

    log(f"\n🏆  submission → {out}", "OK")
    max_l1 = sub[model.weight_cols].abs().sum(axis=1).max()
    log(f"    Max L1 weight : {max_l1:.6f}  (≤1 required)")
    if results:
        log(f"    Sharpe        : {results.get('sharpe', 0):.4f}")
        log(f"    Cumul. return : {results.get('cum_ret',0)*100:.2f}%")


if __name__ == "__main__":
    main()

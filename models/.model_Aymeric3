# 5.  ADVERSARIAL DOMAIN CLASSIFIER
# ─────────────────────────────────────────────────────────────────────────────

class AdversarialDomainClassifier:
    """
    Logistic regression trained to distinguish synthetic (label=0)
    from real (label=1) samples.

    Usage:
      - p_real(x) → probability sample x looks "real"
      - sample_weights = p_real(x)  → up-weight synthetic samples that
        resemble real markets (domain-invariant signal)
      - Feature importance: |coef| → features with small |coef| are
        domain-invariant → prefer those in final model
    """

    def __init__(self, alpha: float = 1.0, n_iter: int = 200):
        self.alpha   = alpha
        self.n_iter  = n_iter
        self._coef   : np.ndarray | None = None
        self._bias   : float = 0.0
        self._feat_m : np.ndarray | None = None
        self._feat_s : np.ndarray | None = None
        self.domain_invariant_mask_: np.ndarray | None = None

    @staticmethod
    def _sigmoid(z: np.ndarray) -> np.ndarray:
        return 1.0 / (1.0 + np.exp(-np.clip(z, -50, 50)))

    def fit(self, X_synth: np.ndarray, X_real: np.ndarray) -> "AdversarialDomainClassifier":
        n_s, n_r = len(X_synth), len(X_real)
        n_feat   = X_synth.shape[1]

        # balance classes
        n_min  = min(n_s, n_r)
        rng    = np.random.default_rng(42)
        idx_s  = rng.choice(n_s, n_min, replace=False)
        idx_r  = rng.choice(n_r, n_min, replace=False)

        X = np.vstack([X_synth[idx_s], X_real[idx_r]])
        y = np.r_[np.zeros(n_min), np.ones(n_min)]

        # standardise
        self._feat_m = X.mean(axis=0)
        self._feat_s = X.std(axis=0) + 1e-8
        X = (X - self._feat_m) / self._feat_s

        # logistic regression via gradient descent + L2
        w = np.zeros(n_feat);  b = 0.0
        lr = 0.05
        for t in range(self.n_iter):
            z   = X @ w + b
            p   = self._sigmoid(z)
            err = p - y
            gw  = (X.T @ err) / len(y) + self.alpha * w / len(y)
            gb  = err.mean()
            lr_t = lr / (1 + 0.01 * t)
            w   -= lr_t * gw
            b   -= lr_t * gb

        self._coef = w;  self._bias = b

        # domain-invariant features: |coef| below median
        threshold   = np.median(np.abs(w))
        self.domain_invariant_mask_ = (np.abs(w) <= threshold)
        log(f"Domain classifier fitted: "
            f"{self.domain_invariant_mask_.sum()}/{n_feat} features "
            f"are domain-invariant (|coef|≤median={threshold:.4f})", "OK")
        return self

    def predict_proba_real(self, X: np.ndarray) -> np.ndarray:
        """Returns P(real) for each sample."""
        Xs = (X - self._feat_m) / self._feat_s
        return self._sigmoid(Xs @ self._coef + self._bias)

    def sample_weights(self, X_synth: np.ndarray,
                       exponent: float = 0.5) -> np.ndarray:
        """
        Up-weight synthetic samples that look like real markets.
        w_i = P(real|x_i)^exponent  (exponent<1 prevents extreme weights)
        """
        p_real = self.predict_proba_real(X_synth)
        # add floor to avoid zeroing out samples entirely
        w = np.clip(p_real, 0.05, 1.0) ** exponent
        return w / w.mean()   # normalise to mean=1



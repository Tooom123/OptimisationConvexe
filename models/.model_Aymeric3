class SubmissionScorerTemplate:
    def __init__(self):
        self.asset_cols = [];  self.pred_cols = [];  self.weight_cols = []

    def set_assets(self, a):
        self.asset_cols  = list(a)
        self.pred_cols   = [f"pred_{c}"   for c in a]
        self.weight_cols = [f"weight_{c}" for c in a]

    def validate_submission_format(self, s):
        req = ["id","date"] + self.pred_cols + self.weight_cols
        miss = [c for c in req if c not in s.columns]
        if miss: raise ValueError(f"Missing: {miss}")
        if s[req].isnull().any().any(): raise ValueError("NaN in submission")
        if s["id"].duplicated().any():  raise ValueError("Duplicate ids")

    def score_predictions(self, preds, real_ret):
        common = [c for c in self.asset_cols if c in real_ret.columns]
        pc     = [f"pred_{c}" for c in common]
        m = real_ret[["id","date"]+common].merge(
            preds[["id","date"]+pc], on=["id","date"], how="inner")
        if m.empty: raise ValueError("No overlap")
        return {"mse": float(np.mean((m[common].values - m[pc].values)**2)),
                "n_rows": int(len(m))}



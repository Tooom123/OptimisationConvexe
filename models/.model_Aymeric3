class RealDataFetcher:
    """
    Tries (in order):
      1. yfinance download
      2. CSV files in  csv_dir/  (columns: Date, Open, High, Low, Close, Volume)
      3. Realistic GARCH market simulator
    Returns a DataFrame of adjusted closing prices, indexed by date.
    """

    def __init__(self, tickers: list = REAL_TICKERS,
                 start: str = "2010-01-01", end: str = "2024-12-31",
                 csv_dir: str | None = None,
                 timeout: float = 10.0):
        self.tickers  = tickers
        self.start    = start
        self.end      = end
        self.csv_dir  = Path(csv_dir) if csv_dir else None
        self.timeout  = timeout
        self.source_  = "unknown"

    # ── 1. yfinance ──────────────────────────────────────────────────────
    def _fetch_yfinance(self) -> pd.DataFrame | None:
        try:
            import yfinance as yf
            import signal as _sig

            # crude timeout via thread
            import threading
            result = [None]
            def _dl():
                try:
                    df = yf.download(self.tickers, start=self.start, end=self.end,
                                     progress=False, threads=True, auto_adjust=True)
                    result[0] = df
                except Exception:
                    pass
            t = threading.Thread(target=_dl, daemon=True)
            t.start()
            t.join(timeout=self.timeout)

            if result[0] is None or result[0].empty:
                return None

            df = result[0]
            # extract Close (auto_adjust=True → Close IS adjusted)
            if isinstance(df.columns, pd.MultiIndex):
                closes = df["Close"].dropna(how="all")
            else:
                closes = df[["Close"]].rename(columns={"Close": self.tickers[0]})

            closes = closes.ffill().dropna(how="all")
            if closes.empty or len(closes) < 100:
                return None
            self.source_ = "yfinance"
            log(f"Real data loaded from yfinance: "
                f"{closes.shape[0]} days × {closes.shape[1]} tickers", "REAL")
            return closes

        except Exception as e:
            log(f"yfinance failed: {e}", "WARN")
            return None

    # ── 2. CSV files ──────────────────────────────────────────────────────
    def _fetch_csv(self) -> pd.DataFrame | None:
        if self.csv_dir is None or not self.csv_dir.exists():
            return None
        frames = {}
        for f in sorted(self.csv_dir.glob("*.csv")):
            try:
                df = pd.read_csv(f, parse_dates=["Date"], index_col="Date")
                col = "Adj Close" if "Adj Close" in df.columns else "Close"
                frames[f.stem] = df[col]
            except Exception:
                pass
        if not frames:
            return None
        closes = pd.DataFrame(frames).ffill().dropna(how="all")
        if len(closes) < 100:
            return None
        self.source_ = "csv"
        log(f"Real data loaded from CSV: "
            f"{closes.shape[0]} days × {closes.shape[1]} assets", "REAL")
        return closes

    # ── 3. GARCH simulator ────────────────────────────────────────────────
    def _simulate_garch(self, n_days: int = 3500,
                        n_assets: int = 20) -> pd.DataFrame:
        """
        Realistic market simulator:
          - Student-t innovations (fat tails, ν=5)
          - GARCH(1,1) volatility clustering
          - Hidden Markov regime (bull / bear)
          - Cross-asset correlation matrix from real markets
          - Momentum + mean-reversion at different timescales
        """
        log("Using GARCH market simulator (no internet access)", "SIM")
        rng   = np.random.default_rng(2024)
        dates = pd.date_range("2010-01-01", periods=n_days, freq="B")

        # --- realistic correlation matrix (block structure like real markets)
        n = n_assets
        # sectors: equity (8), bonds (4), commodities (4), alternatives (4)
        corr = np.eye(n)
        # intra-equity: 0.6–0.8
        for i in range(8):
            for j in range(i+1, 8):
                c = rng.uniform(0.55, 0.80)
                corr[i,j] = corr[j,i] = c
        # intra-bond: 0.5–0.7
        for i in range(8, 12):
            for j in range(i+1, 12):
                c = rng.uniform(0.45, 0.70)
                corr[i,j] = corr[j,i] = c
        # equity-bond: -0.2–0.0 (flight-to-quality)
        for i in range(8):
            for j in range(8, 12):
                c = rng.uniform(-0.25, 0.05)
                corr[i,j] = corr[j,i] = c
        # commodities: 0.3–0.6
        for i in range(12, 16):
            for j in range(i+1, 16):
                c = rng.uniform(0.25, 0.55)
                corr[i,j] = corr[j,i] = c
        # ensure PD
        eigvals = np.linalg.eigvalsh(corr)
        if eigvals.min() < 0.01:
            corr += (0.01 - eigvals.min() + 0.005) * np.eye(n)
            d = np.sqrt(np.diag(corr))
            corr = corr / np.outer(d, d)
        L = np.linalg.cholesky(corr)

        # --- regime switching (Markov chain, 2 states)
        regimes    = np.zeros(n_days, dtype=int)    # 0=bull, 1=bear
        trans      = np.array([[0.985, 0.015],
                                [0.050, 0.950]])     # slow transitions
        regime     = 0
        for t in range(1, n_days):
            regime = rng.choice(2, p=trans[regime])
            regimes[t] = regime

        # --- per-asset GARCH parameters (realistic)
        mu_bull  = rng.uniform(0.0003, 0.0008, n)  # drift in bull
        mu_bear  = rng.uniform(-0.0015,-0.0003, n)  # drift in bear
        omega    = rng.uniform(1e-6, 5e-6, n)
        alpha_g  = rng.uniform(0.05, 0.12, n)       # ARCH term
        beta_g   = rng.uniform(0.82, 0.90, n)       # GARCH term
        h        = np.full(n, 1e-4)                  # initial variance
        nu       = 5.0                               # t-dist df

        returns  = np.zeros((n_days, n))
        for t in range(1, n_days):
            # correlated Student-t innovations
            z_raw  = rng.standard_t(nu, size=n) / np.sqrt(nu/(nu-2))
            z      = L @ z_raw
            sigma_t = np.sqrt(np.maximum(h, 1e-8))
            mu_t   = mu_bull if regimes[t] == 0 else mu_bear
            r_t    = mu_t + sigma_t * z
            # momentum: slight autocorrelation
            if t > 5:
                mom = returns[t-5:t].mean(axis=0) * 0.05
                r_t += mom
            returns[t] = r_t
            # update GARCH variance
            h = omega + alpha_g * r_t**2 + beta_g * h
            h = np.clip(h, 1e-8, 0.01)

        cols   = [f"sim_{i}" for i in range(n)]
        prices = pd.DataFrame(np.exp(np.cumsum(returns, axis=0)),
                              index=dates, columns=cols)
        self.source_ = "garch_simulator"
        log(f"GARCH simulation: {n_days} days × {n} assets, "
            f"bull/bear regime, Student-t(ν=5), GARCH(1,1)", "SIM")
        return prices

    def fetch(self) -> pd.DataFrame:
        """Returns price DataFrame. Falls through sources."""
        for fn in [self._fetch_yfinance, self._fetch_csv]:
            result = fn()
            if result is not None:
                return result
        return self._simulate_garch()



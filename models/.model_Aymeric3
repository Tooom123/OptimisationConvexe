ALPHA_GRID = [0.01, 0.1, 1.0, 10.0, 100.0, 1000.0, 5000.0, 20000.0]


class WeightedRidge:
    """Closed-form weighted Ridge regression."""

    def __init__(self, alpha: float = 1.0):
        self.alpha = alpha
        self._coef : np.ndarray | None = None
        self._bias : float = 0.0

    def fit(self, X: np.ndarray, y: np.ndarray,
            w: np.ndarray | None = None) -> "WeightedRidge":
        n, p = X.shape
        if w is None:
            w = np.ones(n)
        w = w / w.mean()
        Xb  = np.c_[np.ones(n), X]
        W   = np.diag(w)
        A   = Xb.T @ W @ Xb + self.alpha * np.eye(p + 1)
        A[0, 0] -= self.alpha   # don't penalise bias
        b   = Xb.T @ (W @ y)
        try:
            coef = np.linalg.solve(A, b)
        except np.linalg.LinAlgError:
            coef = np.linalg.lstsq(A, b, rcond=None)[0]
        self._bias = coef[0];  self._coef = coef[1:]
        return self

    def predict(self, X: np.ndarray) -> np.ndarray:
        return X @ self._coef + self._bias


class WalkForwardWeightedRidge:
    """
    Walk-forward CV to select alpha, with optional sample weights.
    CV criterion: OOS Sharpe (per-asset).
    """

    def __init__(self, n_folds: int = 5, min_train: int = 80):
        self.n_folds   = n_folds
        self.min_train = min_train
        self.best_alpha_: float = 100.0
        self._model  : WeightedRidge | None = None
        self._feat_m : np.ndarray | None = None
        self._feat_s : np.ndarray | None = None

    def _cv_score(self, X: np.ndarray, y: np.ndarray,
                  w: np.ndarray | None, alpha: float) -> float:
        n    = len(X)
        fold = max((n - self.min_train) // self.n_folds, 10)
        shs  = []
        for k in range(self.n_folds):
            te   = self.min_train + k * fold
            ve   = min(te + fold, n)
            if ve - te < 8:
                continue
            wtr = w[:te] if w is not None else None
            m   = WeightedRidge(alpha)
            m.fit(X[:te], y[:te], wtr)
            pred = m.predict(X[te:ve])
            shs.append(annualised_sharpe(pred * y[te:ve]))
        return float(np.mean(shs)) if shs else -np.inf

    def fit(self, X: np.ndarray, y: np.ndarray,
            w: np.ndarray | None = None) -> "WalkForwardWeightedRidge":
        self._feat_m = X.mean(axis=0)
        self._feat_s = X.std(axis=0) + 1e-8
        Xs = (X - self._feat_m) / self._feat_s

        best, ba = -np.inf, ALPHA_GRID[4]
        for alpha in ALPHA_GRID:
            sc = self._cv_score(Xs, y, w, alpha)
            if sc > best:
                best, ba = sc, alpha
        self.best_alpha_ = ba
        self._model = WeightedRidge(ba)
        self._model.fit(Xs, y, w)
        return self

    def predict(self, X: np.ndarray) -> np.ndarray:
        return self._model.predict((X - self._feat_m) / self._feat_s)


# ─────────────────────────────────────────────────────────────────────────────
# 7.  SIGNAL FILTER  (intersection of synth + real domain coefficients)
# ─────────────────────────────────────────────────────────────────────────────

def filter_signals_cross_domain(coef_synth: np.ndarray,
                                 coef_real:  np.ndarray,
                                 top_k: int | None = None) -> np.ndarray:
    """
    Returns boolean mask of features where:
      1. Sign of coefficient agrees across domains
      2. Both magnitudes are in top_k (optional)
    Philosophy: only trust signals present in BOTH synthetic AND real markets.
    """
    sign_agree = (np.sign(coef_synth) == np.sign(coef_real))
    if top_k is not None:
        imp_s = np.argsort(np.abs(coef_synth))[::-1][:top_k]
        imp_r = np.argsort(np.abs(coef_real))[::-1][:top_k]
        top_mask = np.zeros(len(coef_synth), dtype=bool)
        top_mask[imp_s] = True
        top_mask[imp_r] = True
        return sign_agree & top_mask
    return sign_agree


# ─────────────────────────────────────────────────────────────────────────────
# 8.  LEAN FEATURE ENGINEERING  (synthetic data features)
# ─────────────────────────────────────────────────────────────────────────────

class LeanFeatureEngineer:
    """Minimal feature set from synthetic X — same as v2."""

    def __init__(self, feature_cols: list):
        self.feature_cols = feature_cols
        self._lo: dict = {}
        self._hi: dict = {}

    def fit(self, x_df: pd.DataFrame) -> None:
        for col in self.feature_cols:
            v = x_df[col].dropna().values
            self._lo[col] = float(np.percentile(v, 2))
            self._hi[col] = float(np.percentile(v, 98))

    def _win(self, df: pd.DataFrame) -> pd.DataFrame:
        out = df[self.feature_cols].copy()
        for col in self.feature_cols:
            out[col] = out[col].clip(self._lo[col], self._hi[col])
        return out

    def transform(self, x_df: pd.DataFrame) -> pd.DataFrame:
        df  = x_df.copy().sort_values("date").reset_index(drop=True)
        raw = self._win(df)
        feats = {}
        for col in self.feature_cols:
            s = raw[col]
            feats[col]              = s.values
            feats[f"{col}_lag1"]    = s.shift(1).values
            feats[f"{col}_lag5"]    = s.shift(5).values
            feats[f"{col}_rmean5"]  = s.rolling(5,  min_periods=1).mean().values
            feats[f"{col}_rmean21"] = s.rolling(21, min_periods=1).mean().values
            feats[f"{col}_rstd5"]   = s.rolling(5,  min_periods=2).std().fillna(0).values
            feats[f"{col}_rstd21"]  = s.rolling(21, min_periods=2).std().fillna(0).values
            mu = s.rolling(21, min_periods=1).mean()
            sd = s.rolling(21, min_periods=2).std().replace(0,1e-8).fillna(1e-8)
            feats[f"{col}_z21"]     = ((s - mu) / sd).values
        xbar = raw[self.feature_cols].mean(axis=1)
        feats["xbar"]              = xbar.values
        feats["xbar_lag1"]         = xbar.shift(1).values
        feats["xbar_sign"]         = np.sign(xbar.values)
        feats["xbar_abs"]          = xbar.abs().values
        feats["xbar_rmean21"]      = xbar.rolling(21, min_periods=1).mean().values
        feats["xbar_rstd21"]       = xbar.rolling(21, min_periods=2).std().fillna(0).values
        for thr in [0.3, 0.6]:
            feats[f"xbar_gt_{thr}"] = (xbar >  thr).astype(float).values
            feats[f"xbar_lt_{thr}"] = (xbar < -thr).astype(float).values
        result = pd.DataFrame(feats, index=df.index)
        return result.fillna(0).replace([np.inf, -np.inf], 0)

    def fit_transform(self, x_df: pd.DataFrame) -> pd.DataFrame:
        self.fit(x_df)
        return self.transform(x_df)


# ─────────────────────────────────────────────────────────────────────────────
# 9.  CROSS-DOMAIN ENSEMBLE
# ─────────────────────────────────────────────────────────────────────────────

class CrossDomainEnsemble:
    """
    Per asset:
      1. Fit model_synth on synthetic features  (with adversarial sample weights)
      2. Fit model_real on aligned real features (ridge, different feature space)
      3. Blend predictions: w_s * pred_synth + w_r * pred_real
         where blend weights come from OOS Sharpe on validation split

    Also performs signal filtering: keeps only cross-domain consistent features.
    """

    def __init__(self, asset: str,
                 alpha_penalty: float = 0.3):
        self.asset = asset
        self.alpha_penalty = alpha_penalty
        self._model_synth  : WalkForwardWeightedRidge | None = None
        self._model_real   : WalkForwardWeightedRidge | None = None
        self._signal_mask  : np.ndarray | None = None
        self._w_synth      : float = 1.0
        self._w_real       : float = 0.0
        self._has_real     : bool  = False

    def fit(self,
            X_synth_tr : np.ndarray, y_tr: np.ndarray,
            X_synth_val: np.ndarray, y_val: np.ndarray,
            sample_weights_tr: np.ndarray,
            X_real_tr  : np.ndarray | None = None,
            X_real_val : np.ndarray | None = None,
            domain_mask: np.ndarray | None = None) -> "CrossDomainEnsemble":

        # ── 1. Synthetic model (adversarially weighted)
        self._model_synth = WalkForwardWeightedRidge(n_folds=5)
        self._model_synth.fit(X_synth_tr, y_tr, sample_weights_tr)
        pred_s_val = self._model_synth.predict(X_synth_val)
        pnl_s      = pred_s_val * y_val
        sh_s       = annualised_sharpe(pnl_s)

        # ── 2. Real-domain model (if available)
        sh_r = -np.inf
        if X_real_tr is not None and len(X_real_tr) >= 50:
            self._has_real    = True
            self._model_real  = WalkForwardWeightedRidge(n_folds=5)
            # real data: no adversarial weights (it IS real)
            self._model_real.fit(X_real_tr, y_tr[:len(X_real_tr)])
            if X_real_val is not None and len(X_real_val) > 0:
                pred_r_val = self._model_real.predict(
                    X_real_val[:min(len(y_val), len(X_real_val))]
                )
                l = min(len(pred_r_val), len(y_val))
                pnl_r = pred_r_val[:l] * y_val[:l]
                sh_r  = annualised_sharpe(pnl_r)

        # ── 3. Signal filtering via cross-domain coefficient agreement
        if self._has_real and self._model_real is not None:
            coef_s = self._model_synth._model._coef
            # project real coef to synthetic feature space size
            # (they differ → use min length)
            coef_r = self._model_real._model._coef
            n_min  = min(len(coef_s), len(coef_r))
            self._signal_mask = filter_signals_cross_domain(
                coef_s[:n_min], coef_r[:n_min],
                top_k=min(30, n_min // 2)
            )
            n_kept = self._signal_mask.sum()
            log(f"    [{self.asset}] Signal filter: "
                f"{n_kept}/{n_min} features pass cross-domain test")

        # ── 4. Blend weights by OOS Sharpe
        sh_s_pos = max(0.0, sh_s)
        sh_r_pos = max(0.0, sh_r)
        total    = sh_s_pos + sh_r_pos
        if total < 1e-8:
            self._w_synth = 1.0;  self._w_real = 0.0
        else:
            self._w_synth = sh_s_pos / total
            self._w_real  = sh_r_pos / total

        log(f"    [{self.asset}] Sh_synth={sh_s:.2f} Sh_real={sh_r:.2f}  "
            f"→ blend s={self._w_synth:.2f} r={self._w_real:.2f}  "
            f"α_synth={self._model_synth.best_alpha_:.0f}")
        return self

    def predict(self,
                X_synth: np.ndarray,
                X_real : np.ndarray | None = None) -> np.ndarray:
        pred = self._w_synth * self._model_synth.predict(X_synth)
        if self._has_real and self._model_real is not None and X_real is not None:
            n = min(len(pred), len(X_real))
            real_pred = self._model_real.predict(X_real[:n])
            pred[:n]  = pred[:n] + self._w_real * real_pred
        return pred



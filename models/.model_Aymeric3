# 10.  ASSET POLICY  (from v2 diagnostics)
# ─────────────────────────────────────────────────────────────────────────────

ASSET_MULTIPLIER = {
    "asset_1": 1.00, "asset_2": 0.10, "asset_3": 1.00,
    "asset_4": 0.40, "asset_5": 1.00, "asset_6": 0.10,
    "asset_7": 0.00,  # R²=-0.78 → never allocate
    "asset_8": 0.80, "asset_9": 0.80, "asset_10": 0.80,
    "asset_11": 0.60, "asset_12": 0.60,
}
MAX_ASSET_W = 0.08


# ─────────────────────────────────────────────────────────────────────────────
# 11.  ROBUST PORTFOLIO BUILDER  (dual-covariance)
# ─────────────────────────────────────────────────────────────────────────────

class DualCovariancePortfolioBuilder:
    """
    Covariance estimated from both synthetic predictions AND real market data.
    Sigma_final = (1-gamma) * Sigma_synth + gamma * Sigma_real
    Both are Ledoit-Wolf shrunk.
    """

    def __init__(self, asset_cols: list,
                 target_vol: float = 0.005,
                 cov_window: int = 63,
                 synth_shrink: float = 0.6,
                 real_shrink:  float = 0.7,
                 gamma: float = 0.4,       # weight on real covariance
                 turnover_ema: float = 0.35,
                 max_gross: float = 1.0):
        self.asset_cols  = asset_cols
        self.target_vol  = target_vol
        self.cov_window  = cov_window
        self.synth_shrink = synth_shrink
        self.real_shrink  = real_shrink
        self.gamma        = gamma
        self.turnover_ema = turnover_ema
        self.max_gross    = max_gross
        self._prev_w      = None

    def _lw_shrink(self, data: np.ndarray, rho: float) -> np.ndarray:
        n = data.shape[1]
        if len(data) < 3:
            return np.eye(n)
        S  = np.cov(data.T, ddof=1)
        mu = np.trace(S) / n
        return (1 - rho) * S + rho * mu * np.eye(n)

    def build(self,
              synth_preds: np.ndarray,
              real_preds:  np.ndarray | None = None) -> np.ndarray:
        T, n = synth_preds.shape
        weights = np.zeros((T, n))
        if self._prev_w is None:
            self._prev_w = np.zeros(n)

        for t in range(T):
            mu = synth_preds[t].copy()

            # policy multipliers
            for i, asset in enumerate(self.asset_cols):
                mu[i] *= ASSET_MULTIPLIER.get(asset, 1.0)

            # synthetic covariance
            s0     = max(0, t - self.cov_window)
            Sig_s  = self._lw_shrink(synth_preds[s0:t] if t > 3
                                     else synth_preds[[t]], self.synth_shrink)
            Sigma  = Sig_s

            # blend with real covariance if available
            if real_preds is not None and t < len(real_preds):
                r0    = max(0, t - self.cov_window)
                Sig_r = self._lw_shrink(
                    real_preds[r0:t] if t > 3 else real_preds[[t]],
                    self.real_shrink
                )
                # align dimensions if needed
                n2 = min(n, Sig_r.shape[0])
                Sigma[:n2, :n2] = ((1 - self.gamma) * Sig_s[:n2, :n2]
                                   + self.gamma * Sig_r[:n2, :n2])

            diag_vol = np.sqrt(np.diag(Sigma)) + 1e-8
            w = mu / (diag_vol**2 + 1e-8)
            w = np.clip(w, -MAX_ASSET_W, MAX_ASSET_W)

            # vol targeting
            pv  = float(w @ Sigma @ w)
            pv  = max(pv, 1e-10)
            sc  = min(self.target_vol / np.sqrt(pv), 5.0)
            w  *= sc

            # EMA smoothing (turnover penalty)
            w = self.turnover_ema * w + (1 - self.turnover_ema) * self._prev_w
            self._prev_w = w.copy()

            # L1 projection
            gross = np.abs(w).sum()
            if gross > self.max_gross:
                w = w / gross * self.max_gross
            weights[t] = w

        return weights



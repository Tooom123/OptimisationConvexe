class RealFeatureBuilder:
    """
    Builds a normalised feature matrix from price data.
    Features are made comparable to the synthetic dataset.

    Canonical feature set (per asset):
      - log-return lag-1, lag-2, lag-5
      - rolling mean 5, 21  |  rolling std 5, 21
      - z-score 21
      - RSI-14
      - momentum 10, 21
    Then:
      - cross-sectional z-score each day
      - PCA to n_components
    """

    def __init__(self, n_components: int = 20):
        self.n_components   = n_components
        self._pca_mean      : np.ndarray | None = None
        self._pca_comps     : np.ndarray | None = None
        self._feat_mean     : np.ndarray | None = None
        self._feat_std      : np.ndarray | None = None

    # ── RSI ──────────────────────────────────────────────────────────────
    @staticmethod
    def _rsi(returns: np.ndarray, period: int = 14) -> np.ndarray:
        rsi = np.full(len(returns), 50.0)
        for t in range(period, len(returns)):
            window = returns[t-period:t]
            gains  = window[window > 0].sum()
            losses = -window[window < 0].sum()
            if losses < 1e-10:
                rsi[t] = 100.0
            else:
                rs = gains / losses
                rsi[t] = 100 - 100 / (1 + rs)
        return rsi

    def fit_transform(self, prices: pd.DataFrame) -> pd.DataFrame:
        """prices: (T, n_assets) closing prices."""
        log_ret = np.log(prices / prices.shift(1)).fillna(0).values
        T, n   = log_ret.shape

        feat_blocks = []
        for j in range(n):
            r = pd.Series(log_ret[:, j])
            block = pd.DataFrame({
                "r_lag1"    : r.shift(1).fillna(0),
                "r_lag2"    : r.shift(2).fillna(0),
                "r_lag5"    : r.shift(5).fillna(0),
                "rmean5"    : r.rolling(5,  min_periods=1).mean(),
                "rmean21"   : r.rolling(21, min_periods=1).mean(),
                "rstd5"     : r.rolling(5,  min_periods=2).std().fillna(0),
                "rstd21"    : r.rolling(21, min_periods=2).std().fillna(0),
                "zscore21"  : (r - r.rolling(21).mean()) /
                              (r.rolling(21).std().replace(0,1e-8).fillna(1e-8)),
                "mom10"     : r - r.shift(10).fillna(0),
                "mom21"     : r - r.shift(21).fillna(0),
                "rsi14"     : self._rsi(r.values),
            })
            feat_blocks.append(block.values)

        # stack assets → (T, n_assets × n_per_asset)
        X = np.concatenate(feat_blocks, axis=1)
        X = np.nan_to_num(X, 0.0)

        # cross-sectional z-score per row
        mu  = X.mean(axis=1, keepdims=True)
        sd  = X.std(axis=1,  keepdims=True) + 1e-8
        X   = (X - mu) / sd

        # PCA reduction to n_components
        self._feat_mean = X.mean(axis=0)
        Xc = X - self._feat_mean
        cov = np.cov(Xc.T) + 1e-6 * np.eye(Xc.shape[1])
        eigvals, eigvecs = np.linalg.eigh(cov)
        idx = np.argsort(eigvals)[::-1]
        self._pca_comps = eigvecs[:, idx[:self.n_components]]
        X_pca = Xc @ self._pca_comps

        # standardise
        self._feat_std  = X_pca.std(axis=0) + 1e-8
        X_pca = X_pca / self._feat_std

        result = pd.DataFrame(
            X_pca,
            index=prices.index,
            columns=[f"real_pc{i}" for i in range(self.n_components)]
        )
        log(f"Real features built: {result.shape}  "
            f"(source → {self.n_components} PCA components)", "OK")
        return result

    def transform(self, prices: pd.DataFrame) -> pd.DataFrame:
        """Transform new price data with fitted PCA."""
        log_ret = np.log(prices / prices.shift(1)).fillna(0).values
        T, n   = log_ret.shape
        feat_blocks = []
        for j in range(n):
            r = pd.Series(log_ret[:, j])
            block = pd.DataFrame({
                "r_lag1"  : r.shift(1).fillna(0),
                "r_lag2"  : r.shift(2).fillna(0),
                "r_lag5"  : r.shift(5).fillna(0),
                "rmean5"  : r.rolling(5,  min_periods=1).mean(),
                "rmean21" : r.rolling(21, min_periods=1).mean(),
                "rstd5"   : r.rolling(5,  min_periods=2).std().fillna(0),
                "rstd21"  : r.rolling(21, min_periods=2).std().fillna(0),
                "zscore21": (r - r.rolling(21).mean()) /
                            (r.rolling(21).std().replace(0,1e-8).fillna(1e-8)),
                "mom10"   : r - r.shift(10).fillna(0),
                "mom21"   : r - r.shift(21).fillna(0),
                "rsi14"   : self._rsi(r.values),
            })
            feat_blocks.append(block.values)
        X = np.concatenate(feat_blocks, axis=1)
        X = np.nan_to_num(X, 0.0)
        mu = X.mean(axis=1, keepdims=True);  sd = X.std(axis=1, keepdims=True) + 1e-8
        X  = (X - mu) / sd
        Xc = X - self._feat_mean
        X_pca = (Xc @ self._pca_comps) / self._feat_std
        return pd.DataFrame(X_pca, index=prices.index,
                            columns=[f"real_pc{i}" for i in range(self.n_components)])



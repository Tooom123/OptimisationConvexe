def annualised_sharpe(r: np.ndarray, eps: float = 1e-9) -> float:
    r = r[np.isfinite(r)]
    if len(r) < 5: return 0.0
    return float(np.mean(r) / (np.std(r, ddof=1) + eps) * np.sqrt(252))

def rolling_sharpe_std(r: np.ndarray, w: int = 42) -> float:
    vals = [annualised_sharpe(r[max(0,i-w):i]) for i in range(w, len(r))]
    return float(np.std(vals)) if vals else 0.0

def temporal_corr(y: np.ndarray, yh: np.ndarray) -> float:
    m = np.isfinite(y) & np.isfinite(yh)
    return float(np.corrcoef(y[m], yh[m])[0,1]) if m.sum() > 5 else 0.0

def r_squared(y: np.ndarray, yh: np.ndarray) -> float:
    ss_r = np.sum((y - yh)**2);  ss_t = np.sum((y - np.mean(y))**2)
    return float(1 - ss_r / (ss_t + 1e-12))



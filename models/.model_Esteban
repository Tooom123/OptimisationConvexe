# 4.  ENSEMBLE PREDICTOR  (Sharpe-weighted, with asymmetric loss bonus)
# ─────────────────────────────────────────────────────────────────────────────

class EnsemblePredictor:
    """
    Weighted ensemble: weights ∝ max(0, Sharpe_val).
    Asymmetric bonus: models that capture large moves get extra weight.
    """
    def __init__(self, models: list):
        self.models   = models
        self.weights_ = None

    def fit(self, X_tr, y_tr, X_val, y_val):
        sharpes = []
        for name, m in self.models:
            m.fit(X_tr, y_tr)
            val_pred = m.predict(X_val)
            pnl      = val_pred * y_val

            # Asymmetric bonus: weight extreme captures more (top-20% returns)
            sh_base  = sharpe(pnl)
            q80      = np.percentile(np.abs(y_val), 80)
            big_mask = np.abs(y_val) > q80
            sh_extreme = sharpe(pnl[big_mask]) if big_mask.sum() > 5 else 0.0
            # Combined: 70% base Sharpe + 30% extreme capture
            sh_combined = 0.7 * sh_base + 0.3 * max(0.0, sh_extreme)
            sharpes.append(max(0.0, sh_combined))
            log(f"  [{name}] val Sharpe={sh_base:.3f}  extreme={sh_extreme:.3f}")

        total = sum(sharpes)
        if total < 1e-9:
            self.weights_ = np.ones(len(sharpes)) / len(sharpes)
        else:
            self.weights_ = np.array(sharpes) / total
        log(f"  Ensemble weights: "
            f"{dict(zip([n for n,_ in self.models], np.round(self.weights_,3)))}")
        return self

    def predict(self, X):
        preds = np.stack([m.predict(X) for _, m in self.models], axis=1)
        return preds @ self.weights_


# ─────────────────────────────────────────────────────────────────────────────
# 5.  COVARIANCE ESTIMATOR  (Ledoit-Wolf, unchanged)
# ─────────────────────────────────────────────────────────────────────────────

class RobustCovarianceEstimator:
    def __init__(self, window: int = 63, shrinkage=None):
        self.window    = window
        self.shrinkage = shrinkage

    def estimate(self, returns: np.ndarray) -> np.ndarray:
        T, n = returns.shape
        if T < 3:
            return np.eye(n)
        S = np.cov(returns.T, ddof=1)
        if n == 1:
            return S.reshape(1, 1)
        if self.shrinkage is None:
            mu    = np.trace(S) / n
            delta = float(np.sum(S ** 2))
            rho   = min(1.0, ((n + 2) / (n * T)) * delta /
                        (np.trace(S @ S) / n + (np.trace(S) ** 2 / n
                         - 2 * np.trace(S @ S) / n + delta) / T))
            rho = max(0.0, min(1.0, rho))
        else:
            rho = self.shrinkage
            mu  = np.trace(S) / n
        return (1 - rho) * S + rho * mu * np.eye(n)


# ─────────────────────────────────────────────────────────────────────────────
# 6.  REGIME DETECTOR  (NEW)
# ─────────────────────────────────────────────────────────────────────────────

class RegimeDetector:
    """
    Simple volatility-based regime classifier.
    Compares recent 21-day vol to trailing 63-day vol.
    Regimes: 'high_vol' (risk-off) | 'normal' | 'low_vol' (risk-on)
    """

    def detect(self, returns_window: np.ndarray) -> str:
        if len(returns_window) < 10:
            return "normal"
        port_ret = returns_window.mean(axis=1) if returns_window.ndim == 2 else returns_window
        recent_vol  = np.std(port_ret[-21:]) if len(port_ret) >= 21 else np.std(port_ret)
        long_vol    = np.std(port_ret[-63:]) if len(port_ret) >= 63 else np.std(port_ret)
        if long_vol < 1e-8:
            return "normal"
        ratio = recent_vol / long_vol
        if ratio > 1.40:
            return "high_vol"
        elif ratio < 0.65:
            return "low_vol"
        return "normal"


# ─────────────────────────────────────────────────────────────────────────────
# 7.  SIGNAL TRANSFORMER  (NEW — core of aggressive strategy)
# ─────────────────────────────────────────────────────────────────────────────

class AggressiveSignalTransformer:
    """
    Converts raw model predictions into exploitable trading signals.

    Pipeline:
      1. Threshold  : zero-out signals below confidence cutoff
      2. Amplify    : power transform OR tanh — non-linear scaling
      3. Vol-Scale  : weight ∝ signal / asset_vol  (risk-normalised)
      4. Top-K      : zero out all but top-K assets by |signal|
      5. Leverage   : scale the entire signal vector

    Returns a weight vector (not yet L1-projected).
    """

    def __init__(self, cfg: dict):
        self.p                    = cfg.get("power_p",       1.5)
        self.use_tanh             = cfg.get("use_tanh",       True)
        self.tanh_scale           = cfg.get("tanh_scale",     2.0)
        self.threshold            = cfg.get("threshold",      0.02)
        self.top_k                = cfg.get("top_k",          6)
        self.max_weight_cap       = cfg.get("max_weight_cap", 0.35)
        self.base_leverage        = cfg.get("base_leverage",  0.75)
        self.max_leverage         = cfg.get("max_leverage",   0.90)
        self.vol_scaling          = cfg.get("vol_scaling",    True)
        self.vol_target           = cfg.get("vol_target",     0.14)
        self.regime_hi            = cfg.get("regime_scale_high_vol", 0.65)
        self.regime_lo            = cfg.get("regime_scale_low_vol",  1.08)
        self.regime_detector      = RegimeDetector()

    def transform(self, pred: np.ndarray,
                  history: np.ndarray | None = None) -> np.ndarray:
        """
        pred    : shape (n_assets,)  — raw model predictions for one time step
        history : shape (T, n_assets) — past returns / pred proxy for vol
        Returns : weight vector shape (n_assets,)
        """
        signal = pred.copy().astype(float)
        k = len(signal)

        # ── 1. THRESHOLD — cut weak signals
        signal = np.where(np.abs(signal) < self.threshold, 0.0, signal)

        # ── 2. AMPLIFY
        if self.use_tanh:
            # tanh: gentle saturation of extreme signals + non-linearity
            signal = np.tanh(signal * self.tanh_scale)
        else:
            # Power transform: sign(x) * |x|^p  (p>1 amplifies strong signals)
            signal = np.sign(signal) * (np.abs(signal) ** self.p)

        # ── 3. VOL SCALING  (risk-normalised weights)
        if self.vol_scaling and history is not None and len(history) >= 5:
            asset_vols = np.std(history[-min(len(history), 63):], axis=0) * np.sqrt(252)
            asset_vols = np.maximum(asset_vols, 1e-4)
            signal     = signal / asset_vols * self.vol_target

        # ── 4. TOP-K SELECTION — concentrate capital
        if self.top_k > 0 and self.top_k < k:
            abs_sig      = np.abs(signal)
            top_idx      = np.argsort(abs_sig)[-self.top_k:]
            mask         = np.zeros(k, dtype=bool)
            mask[top_idx] = True
            signal       = signal * mask

        # ── 5. REGIME-AWARE LEVERAGE
        regime = "normal"
        if history is not None and len(history) >= 10:
            regime = self.regime_detector.detect(history)

        lever = self.base_leverage
        if regime == "high_vol":
            lever *= self.regime_hi
        elif regime == "low_vol":
            lever = min(lever * self.regime_lo, self.max_leverage)
        lever = min(lever, self.max_leverage)

        # Dynamic leverage: also scale by signal conviction
        conviction = np.abs(signal).sum() / (k + 1e-8)
        dyn_lever  = lever * (0.5 + 0.5 * min(conviction * 5, 1.0))
        dyn_lever  = max(dyn_lever, lever * 0.4)   # floor

        signal = signal * dyn_lever

        # ── 6. CAP individual positions
        signal = np.clip(signal, -self.max_weight_cap, self.max_weight_cap)

        return signal


# ─────────────────────────────────────────────────────────────────────────────
# 8.  PORTFOLIO OPTIMIZER  (extended with return-biased mode)
# ─────────────────────────────────────────────────────────────────────────────

class PortfolioOptimizer:
    """
    Given mu and Sigma, maximises chosen objective.
    Methods:
      'sharpe'        — gradient ascent on Sharpe (original)
      'mv'            — mean-variance
      'risk_parity'   — inverse vol
      'return_biased' — Sigma^{-1} mu / risk_aversion (NEW, aggressive)
    """

    def __init__(self, method="sharpe", max_gross=1.0, risk_aversion=1.0,
                 noisy_asset_ids=None, noisy_penalty=5.0):
        self.method          = method
        self.max_gross       = max_gross
        self.risk_aversion   = risk_aversion
        self.noisy_asset_ids = noisy_asset_ids or []
        self.noisy_penalty   = noisy_penalty

    def optimise(self, mu, Sigma):
        if self.method == "return_biased":
            return self._return_biased(mu, Sigma)
        elif self.method == "mv":
            return self._mv_opt(mu, Sigma)
        elif self.method == "risk_parity":
            return self._risk_parity(Sigma)
        return self._sharpe_opt(mu, Sigma)

    def _regularise_sigma(self, Sigma):
        n = Sigma.shape[0]
        min_eig = np.linalg.eigvalsh(Sigma).min()
        if min_eig < 1e-6:
            Sigma = Sigma + (abs(min_eig) + 1e-6) * np.eye(n)
        for idx in self.noisy_asset_ids:
            if idx < n:
                Sigma[idx, idx] *= self.noisy_penalty
        return Sigma

    def _sharpe_opt(self, mu, Sigma):
        Sigma = self._regularise_sigma(Sigma.copy())
        try:
            Sigma_inv = np.linalg.inv(Sigma)
        except np.linalg.LinAlgError:
            Sigma_inv = np.linalg.pinv(Sigma)
        w  = (Sigma_inv @ mu).copy()
        lr = 0.1
        for _ in range(200):
            port_var = max(float(w @ Sigma @ w), 1e-10)
            port_ret = float(w @ mu)
            denom    = np.sqrt(port_var)
            grad     = (mu * denom - port_ret * (Sigma @ w) / denom) / port_var
            w        = self._project(w + lr * grad)
        return w

    def _mv_opt(self, mu, Sigma):
        Sigma = self._regularise_sigma(Sigma.copy())
        try:
            Sigma_inv = np.linalg.inv(Sigma)
        except np.linalg.LinAlgError:
            Sigma_inv = np.linalg.pinv(Sigma)
        return self._project(Sigma_inv @ mu / self.risk_aversion)

    def _risk_parity(self, Sigma):
        Sigma = self._regularise_sigma(Sigma.copy())
        vols  = np.sqrt(np.diag(Sigma))
        w     = 1.0 / np.maximum(vols, 1e-8)
        return self._project(w / w.sum())

    def _return_biased(self, mu, Sigma):
        """
        Aggressive: Sigma^{-1} mu / risk_aversion.
        Lower risk_aversion → more concentrated bets.
        Sigma regularised but with lower penalty than conservative mode.
        """
        Sigma = self._regularise_sigma(Sigma.copy())
        try:
            Sigma_inv = np.linalg.inv(Sigma)
        except np.linalg.LinAlgError:
            Sigma_inv = np.linalg.pinv(Sigma)
        # Pure return-maximising tilt: fully exploits mu direction
        w_raw = Sigma_inv @ mu
        # Scale by 1/risk_aversion to control aggressiveness
        w_raw = w_raw / (self.risk_aversion + 1e-8)
        return self._project(w_raw)

    def _project(self, w):
        """L1-ball projection + individual weight clip."""
        w     = np.clip(w, -1.0, 1.0)
        gross = np.sum(np.abs(w))
        if gross > self.max_gross:
            w = w / gross * self.max_gross
        return w



class RidgeModel:
    def __init__(self, alpha: float = 1.0):
        self.alpha = alpha
        self.coef_ = None

    def fit(self, X, y):
        X = np.c_[np.ones(len(X)), X]
        n, p = X.shape
        A = X.T @ X + self.alpha * np.eye(p)
        A[0, 0] -= self.alpha
        self.coef_ = np.linalg.solve(A, X.T @ y)
        return self

    def predict(self, X):
        return np.c_[np.ones(len(X)), X] @ self.coef_


class LassoSGD:
    def __init__(self, alpha=0.01, lr=1e-3, n_iter=500, batch=64, tol=1e-5):
        self.alpha  = alpha;  self.lr = lr
        self.n_iter = n_iter; self.batch = batch; self.tol = tol
        self.coef_  = None;   self.bias_ = 0.0

    def fit(self, X, y):
        n, p   = X.shape
        w, b   = np.zeros(p), 0.0
        prev   = np.inf
        rng    = np.random.default_rng(42)
        for t in range(self.n_iter):
            idx      = rng.choice(n, min(self.batch, n), replace=False)
            Xb, yb   = X[idx], y[idx]
            res      = Xb @ w + b - yb
            grad_w   = (Xb.T @ res) / len(idx) + self.alpha * np.sign(w)
            grad_b   = res.mean()
            lr_t     = self.lr * (1 + np.cos(np.pi * t / self.n_iter)) / 2 + 1e-6
            w       -= lr_t * grad_w;  b -= lr_t * grad_b
            if t % 50 == 0:
                loss = np.mean((X @ w + b - y) ** 2) + self.alpha * np.sum(np.abs(w))
                if abs(prev - loss) < self.tol:
                    break
                prev = loss
        self.coef_ = w;  self.bias_ = b
        return self

    def predict(self, X):
        return X @ self.coef_ + self.bias_


class ElasticNetSGD:
    def __init__(self, alpha=0.01, l1_ratio=0.5, lr=1e-3, n_iter=500, batch=64):
        self.alpha = alpha; self.l1_ratio = l1_ratio
        self.lr    = lr;    self.n_iter   = n_iter; self.batch = batch
        self.coef_ = None;  self.bias_    = 0.0

    def fit(self, X, y):
        n, p = X.shape
        w, b = np.zeros(p), 0.0
        rng  = np.random.default_rng(42)
        for t in range(self.n_iter):
            idx    = rng.choice(n, min(self.batch, n), replace=False)
            Xb, yb = X[idx], y[idx]
            res    = Xb @ w + b - yb
            l1     = self.alpha * self.l1_ratio * np.sign(w)
            l2     = self.alpha * (1 - self.l1_ratio) * w
            grad_w = (Xb.T @ res) / len(idx) + l1 + l2
            grad_b = res.mean()
            lr_t   = self.lr / (1 + 0.001 * t)
            w     -= lr_t * grad_w;  b -= lr_t * grad_b
        self.coef_ = w;  self.bias_ = b
        return self

    def predict(self, X):
        return X @ self.coef_ + self.bias_


class MLPFromScratch:
    def __init__(self, hidden1=64, hidden2=32, lr=1e-3, n_iter=300,
                 batch=128, dropout=0.1, weight_decay=1e-4):
        self.h1 = hidden1; self.h2 = hidden2; self.lr = lr
        self.n_iter = n_iter; self.batch = batch
        self.dropout = dropout; self.weight_decay = weight_decay
        self.params = {}

    @staticmethod
    def relu(x):       return np.maximum(0, x)
    @staticmethod
    def relu_grad(x):  return (x > 0).astype(float)

    def _init_params(self, n_in):
        rng = np.random.default_rng(7)
        self.params = {
            "W1": rng.standard_normal((n_in,   self.h1)) * np.sqrt(2 / n_in),
            "b1": np.zeros(self.h1),
            "W2": rng.standard_normal((self.h1, self.h2)) * np.sqrt(2 / self.h1),
            "b2": np.zeros(self.h2),
            "W3": rng.standard_normal((self.h2, 1))      * np.sqrt(2 / self.h2),
            "b3": np.zeros(1),
        }
        self.m = {k: np.zeros_like(v) for k, v in self.params.items()}
        self.v = {k: np.zeros_like(v) for k, v in self.params.items()}
        self.t = 0

    def _forward(self, X, training=False):
        W1, b1 = self.params["W1"], self.params["b1"]
        W2, b2 = self.params["W2"], self.params["b2"]
        W3, b3 = self.params["W3"], self.params["b3"]
        z1 = X @ W1 + b1;  a1 = self.relu(z1)
        mask1 = None
        if training and self.dropout > 0:
            mask1 = (np.random.rand(*a1.shape) > self.dropout) / (1 - self.dropout)
            a1    = a1 * mask1
        z2 = a1 @ W2 + b2;  a2 = self.relu(z2)
        mask2 = None
        if training and self.dropout > 0:
            mask2 = (np.random.rand(*a2.shape) > self.dropout) / (1 - self.dropout)
            a2    = a2 * mask2
        z3    = a2 @ W3 + b3
        cache = (X, z1, a1, mask1, z2, a2, mask2, z3)
        return z3.squeeze(), cache

    def _backward(self, cache, y):
        X, z1, a1, mask1, z2, a2, mask2, z3 = cache
        n   = len(y)
        dz3 = (z3.squeeze() - y) / n
        dW3 = a2.T @ dz3[:, None];   db3 = dz3.sum(keepdims=True)
        da2 = dz3[:, None] @ self.params["W3"].T
        if mask2 is not None: da2 = da2 * mask2
        dz2 = da2 * self.relu_grad(z2)
        dW2 = a1.T @ dz2;            db2 = dz2.sum(axis=0)
        da1 = dz2 @ self.params["W2"].T
        if mask1 is not None: da1 = da1 * mask1
        dz1 = da1 * self.relu_grad(z1)
        dW1 = X.T @ dz1;             db1 = dz1.sum(axis=0)
        grads = {"W1": dW1, "b1": db1, "W2": dW2, "b2": db2, "W3": dW3, "b3": db3}
        for k in ["W1", "W2", "W3"]:
            grads[k] += self.weight_decay * self.params[k]
        return grads

    def _adam_step(self, grads):
        self.t += 1
        b1, b2, eps = 0.9, 0.999, 1e-8
        for k in self.params:
            self.m[k] = b1 * self.m[k] + (1 - b1) * grads[k]
            self.v[k] = b2 * self.v[k] + (1 - b2) * grads[k] ** 2
            m_hat = self.m[k] / (1 - b1 ** self.t)
            v_hat = self.v[k] / (1 - b2 ** self.t)
            self.params[k] -= self.lr * m_hat / (np.sqrt(v_hat) + eps)

    def fit(self, X, y):
        self._init_params(X.shape[1])
        rng = np.random.default_rng(42)
        best_loss, best_params = np.inf, None
        patience, no_improve = 20, 0
        for epoch in range(self.n_iter):
            idx = rng.permutation(len(X))
            for start in range(0, len(X), self.batch):
                b_idx = idx[start: start + self.batch]
                _, cache = self._forward(X[b_idx], training=True)
                grads = self._backward(cache, y[b_idx])
                self._adam_step(grads)
            if epoch % 10 == 0:
                preds, _ = self._forward(X, training=False)
                loss = np.mean((preds - y) ** 2)
                if loss < best_loss - 1e-6:
                    best_loss, best_params, no_improve = loss, deepcopy(self.params), 0
                else:
                    no_improve += 1
                if no_improve >= patience:
                    break
        if best_params is not None:
            self.params = best_params
        return self

    def predict(self, X):
        preds, _ = self._forward(X, training=False)
        return preds


class SimpleGBM:
    def __init__(self, n_estimators=50, lr=0.1, subsample=0.8, alpha=1.0):
        self.n_estimators = n_estimators; self.lr = lr
        self.subsample    = subsample;    self.alpha = alpha
        self.learners     = [];           self.baseline_ = 0.0

    def fit(self, X, y):
        self.baseline_ = np.mean(y)
        residuals = y - self.baseline_
        rng = np.random.default_rng(42)
        self.learners = []
        for _ in range(self.n_estimators):
            n   = len(X)
            idx = rng.choice(n, int(n * self.subsample), replace=False)
            lrn = RidgeModel(alpha=self.alpha)
            lrn.fit(X[idx], residuals[idx])
            upd       = lrn.predict(X)
            residuals -= self.lr * upd
            self.learners.append(lrn)
        return self

    def predict(self, X):
        out = np.full(len(X), self.baseline_)
        for lrn in self.learners:
            out += self.lr * lrn.predict(X)
        return out



# 9.  SUBMISSION SCORER
# ─────────────────────────────────────────────────────────────────────────────

class SubmissionScorerTemplate:
    def __init__(self):
        self.asset_cols  = []
        self.pred_cols   = []
        self.weight_cols = []

    def set_assets(self, asset_cols):
        self.asset_cols  = list(asset_cols)
        self.pred_cols   = [f"pred_{c}"   for c in self.asset_cols]
        self.weight_cols = [f"weight_{c}" for c in self.asset_cols]

    def validate_submission_format(self, submission):
        required = ["id", "date"] + self.pred_cols + self.weight_cols
        missing  = [c for c in required if c not in submission.columns]
        if missing:
            raise ValueError(f"Missing columns: {missing}")
        if submission[required].isnull().any().any():
            raise ValueError("Submission contains NaN values.")
        if submission["id"].duplicated().any():
            raise ValueError("Submission contains duplicate ids.")

    def score_predictions(self, predictions, realized_returns):
        common = [c for c in self.asset_cols if c in realized_returns.columns]
        if not common:
            raise ValueError("No common asset columns.")
        pred_cols = [f"pred_{c}" for c in common]
        merged = realized_returns[["id", "date"] + common].merge(
            predictions[["id", "date"] + pred_cols], on=["id", "date"], how="inner"
        )
        if merged.empty:
            raise ValueError("No overlapping rows.")
        y_true = merged[common].to_numpy(dtype=float)
        y_pred = merged[pred_cols].to_numpy(dtype=float)
        return {"mse": float(np.mean((y_true - y_pred) ** 2)),
                "n_rows": int(len(merged))}


# ─────────────────────────────────────────────────────────────────────────────
# 10. MAIN MODEL
# ─────────────────────────────────────────────────────────────────────────────

class PortfolioChallengeModel:
    """
    Aggressive PnL-maximising portfolio model.

    Key improvements over baseline:
      • Per-strategy signal transformation (threshold + power/tanh + vol-scale + top-k)
      • Regime-aware dynamic leverage
      • Return-biased portfolio optimizer
      • Asymmetric loss in ensemble weighting
      • Multi-strategy comparison with automatic selection:
          Score = CumReturn - 0.5·MaxDrawdown + 0.3·Sharpe
    """

    VAL_FRAC     = 0.20
    PENALTY_VAR  = 0.5
    SPECIAL_78   = ["asset_7",  "asset_8"]
    SPECIAL_9    = ["asset_9"]
    SPECIAL_10   = ["asset_10"]
    NOISY        = ["asset_11", "asset_12"]

    # Selection score parameters
    SEL_LAMBDA   = 0.50   # drawdown penalty
    SEL_GAMMA    = 0.30   # Sharpe bonus

    def __init__(self):
        self.feature_cols    = []
        self.asset_cols      = []
        self.pred_cols       = []
        self.weight_cols     = []
        self.feat_eng        = None
        self.per_asset_models = {}
        self.cov_estimator   = RobustCovarianceEstimator()
        self.regime_detector = RegimeDetector()
        self.optimizer       = None
        self._xbar_idx       = 0
        self._feat_cols_eng  = []
        self._feat_mean      = None
        self._feat_std       = None

    # ── I/O ──────────────────────────────────────────────────────────────────

    def read_table(self, path) -> pd.DataFrame:
        path = Path(path)
        if path.suffix.lower() == ".parquet":
            return pd.read_parquet(path)
        raise ValueError(f"Unsupported format: {path}")

    def load_data(self, data_dir: str = "data") -> dict:
        data_dir = Path(data_dir)
        x_train  = self.read_table(data_dir / "X_train.parquet")
        r_train  = self.read_table(data_dir / "R_train.parquet")
        x_test   = self.read_table(data_dir / "X_test.parquet")
        self.feature_cols = [c for c in x_train.columns if c not in ("id","date","split")]
        self.asset_cols   = [c for c in r_train.columns if c not in ("id","date","split")]
        self.pred_cols    = [f"pred_{c}"   for c in self.asset_cols]
        self.weight_cols  = [f"weight_{c}" for c in self.asset_cols]
        log(f"Loaded: {len(x_train)} train | {len(x_test)} test | "
            f"{len(self.feature_cols)} features | {len(self.asset_cols)} assets", "OK")
        return {"X_train": x_train, "R_train": r_train, "X_test": x_test}

    # ── Model Suite ───────────────────────────────────────────────────────────

    def _build_model_suite(self, asset: str, X_shape: int):
        base_models = [
            ("ridge_1",    RidgeModel(alpha=0.1)),
            ("ridge_10",   RidgeModel(alpha=10.0)),
            ("lasso",      LassoSGD(alpha=0.01,  n_iter=300)),
            ("elasticnet", ElasticNetSGD(alpha=0.01, l1_ratio=0.5, n_iter=300)),
            ("gbm",        SimpleGBM(n_estimators=40, lr=0.05, alpha=1.0)),
        ]
        if asset in self.SPECIAL_78:
            base_models += [
                ("mlp_small", MLPFromScratch(hidden1=32, hidden2=16, n_iter=200)),
                ("mlp_large", MLPFromScratch(hidden1=64, hidden2=32, n_iter=300)),
            ]
        if asset in self.SPECIAL_9:
            base_models += [
                ("mlp_jump", MLPFromScratch(hidden1=64, hidden2=32, n_iter=250)),
            ]
        if asset in self.NOISY:
            base_models = [
                ("ridge_strong", RidgeModel(alpha=100.0)),
                ("ridge_med",    RidgeModel(alpha=10.0)),
            ]
        return base_models

    # ── Fit ──────────────────────────────────────────────────────────────────

    def fit(self, x_train: pd.DataFrame, r_train: pd.DataFrame) -> None:
        log("FEATURE ENGINEERING", "SECTION")
        x_train = x_train.sort_values("date").reset_index(drop=True)
        r_train = r_train.sort_values("date").reset_index(drop=True)
        common_ids = set(x_train["id"]).intersection(r_train["id"])
        x_tr = x_train[x_train["id"].isin(common_ids)].reset_index(drop=True)
        r_tr = r_train[r_train["id"].isin(common_ids)].reset_index(drop=True)

        self.feat_eng    = FeatureEngineer(self.feature_cols)
        X_eng            = self.feat_eng.fit_transform(x_tr)
        self._feat_cols_eng = list(X_eng.columns)
        self._xbar_idx   = (self._feat_cols_eng.index("xbar")
                            if "xbar" in self._feat_cols_eng else 0)
        log(f"Engineered feature matrix: {X_eng.shape}", "OK")

        n     = len(X_eng)
        n_val = max(int(n * self.VAL_FRAC), 30)
        n_tr  = n - n_val
        X_tr_arr  = X_eng.iloc[:n_tr].values.astype(float)
        X_val_arr = X_eng.iloc[n_tr:].values.astype(float)

        self._feat_mean = X_tr_arr.mean(axis=0)
        self._feat_std  = X_tr_arr.std(axis=0) + 1e-8
        X_tr_arr        = (X_tr_arr  - self._feat_mean) / self._feat_std
        X_val_arr       = (X_val_arr - self._feat_mean) / self._feat_std

        noisy_indices = [i for i, a in enumerate(self.asset_cols) if a in self.NOISY]
        self.optimizer = PortfolioOptimizer(
            method="sharpe",
            noisy_asset_ids=noisy_indices,
            noisy_penalty=6.0,
        )

        log("PER-ASSET MODEL TRAINING", "SECTION")
        all_val_pnl = []

        for asset in self.asset_cols:
            if asset not in r_tr.columns:
                log(f"  {asset}: not found in returns, skipping", "WARN")
                continue
            log(f"\n  ── {asset.upper()} ──")
            y_all = r_tr[asset].values.astype(float)
            y_tr  = y_all[:n_tr]
            y_val = y_all[n_tr:]

            models_suite = self._build_model_suite(asset, X_tr_arr.shape[1])
            if asset in self.SPECIAL_9:
                jump = ThresholdJumpPredictor()
                jump.fit(X_tr_arr, y_tr, xbar_idx=self._xbar_idx, threshold=0.4)
                models_suite = [("jump", jump)] + models_suite

            ensemble = EnsemblePredictor(models_suite)
            ensemble.fit(X_tr_arr, y_tr, X_val_arr, y_val)

            val_pred = ensemble.predict(X_val_arr)
            val_pnl  = val_pred * y_val
            all_val_pnl.append(val_pnl)
            sh = sharpe(val_pnl)
            log(f"  → Val Sharpe={sh:.3f}", "OK")
            self.per_asset_models[asset] = ensemble

        if all_val_pnl:
            min_len  = min(len(p) for p in all_val_pnl)
            pnl_mat  = np.stack([p[:min_len] for p in all_val_pnl], axis=1)
            port_ret = pnl_mat.mean(axis=1)
            log(f"\nPortfolio Val Sharpe (equal-weight): {sharpe(port_ret):.3f}", "OK")

    # ── Predict ──────────────────────────────────────────────────────────────

    def predict_returns(self, x_df: pd.DataFrame) -> pd.DataFrame:
        if not self.pred_cols:
            raise ValueError("Model not initialized. Call load_data() first.")
        x_df  = x_df.sort_values("date").reset_index(drop=True)
        X_eng = self.feat_eng.transform(x_df)
        X_arr = (X_eng.values.astype(float) - self._feat_mean) / self._feat_std

        pred_matrix = np.zeros((len(x_df), len(self.asset_cols)))
        for i, asset in enumerate(self.asset_cols):
            if asset in self.per_asset_models:
                pred_matrix[:, i] = self.per_asset_models[asset].predict(X_arr)

        return pd.DataFrame(pred_matrix, columns=self.pred_cols, index=x_df.index)

    # ── Weight Building (per strategy) ───────────────────────────────────────

    def build_weights_strategy(
        self,
        pred_df: pd.DataFrame,
        strategy_name: str = "hybrid",
        returns_history: np.ndarray | None = None,
    ) -> pd.DataFrame:
        """
        Build portfolio weights using a named strategy configuration.

        Parameters
        ----------
        pred_df         : DataFrame of raw model predictions (n_rows × n_assets)
        strategy_name   : one of 'conservative', 'aggressive', 'hybrid'
        returns_history : (T, n_assets) array of past returns for vol/regime estimation

        Returns
        -------
        DataFrame of weights (n_rows × n_assets), L1 ≤ 1 per row
        """
        cfg         = STRATEGY_CONFIGS[strategy_name]
        transformer = AggressiveSignalTransformer(cfg)

        # Override optimizer method and risk aversion from strategy config
        noisy_indices = [i for i, a in enumerate(self.asset_cols) if a in self.NOISY]
        opt = PortfolioOptimizer(
            method          = cfg["optimizer_method"] if cfg["optimizer_method"] != "return_biased" else "return_biased",
            max_gross       = 1.0,
            risk_aversion   = cfg["risk_aversion"],
            noisy_asset_ids = noisy_indices,
            noisy_penalty   = 4.0,
        )

        raw_preds = pred_df.to_numpy(dtype=float)
        n, k      = raw_preds.shape
        weights   = np.zeros_like(raw_preds)

        # Build return proxy history for vol / regime detection
        if returns_history is None:
            returns_history = raw_preds   # use predictions as proxy

        for t in range(n):
            mu        = raw_preds[t].copy()
            hist_end  = t
            hist_data = returns_history[max(0, hist_end - 126): hist_end] if hist_end > 0 else returns_history[:1]

            # Cross-sectional normalisation: predictions are on daily-return scale
            # (~1e-3) while thresholds are designed for unit-std signals.
            # Dividing by cross-sectional std makes the threshold scale-invariant.
            mu_cs_std = np.std(mu)
            if mu_cs_std > 1e-8:
                mu = mu / mu_cs_std

            # ── Signal transformation (threshold → amplify → vol-scale → top-k)
            signal = transformer.transform(mu, hist_data)

            # ── Portfolio optimization on transformed signal
            start_cov  = max(0, t - self.cov_estimator.window)
            window_cov = returns_history[start_cov: t] if t > 0 else returns_history[:1]
            Sigma      = (self.cov_estimator.estimate(window_cov)
                         if len(window_cov) >= 3 else np.eye(k))

            try:
                w = opt.optimise(signal, Sigma)
            except Exception:
                gross = np.abs(signal).sum() + 1e-8
                w     = signal / gross

            # ── Final per-position cap + L1 enforcement
            max_cap = cfg["max_weight_cap"]
            w       = np.clip(w, -max_cap, max_cap)
            gross   = np.abs(w).sum()
            if gross > 1.0:
                w = w / gross

            weights[t] = w

        return pd.DataFrame(weights, columns=self.weight_cols, index=pred_df.index)

    # ── Legacy build_weights (for backward compat) ───────────────────────────

    def build_weights(self, pred_df: pd.DataFrame,
                      x_df=None) -> pd.DataFrame:
        """Kept for backward compatibility — uses hybrid strategy."""
        return self.build_weights_strategy(pred_df, strategy_name="hybrid")

    # ── Strategy Evaluation + Selection ──────────────────────────────────────

    def evaluate_strategy_on_train(
        self,
        strategy_name: str,
        pred_train: pd.DataFrame,
        r_train: pd.DataFrame,
        returns_proxy: np.ndarray,
    ) -> dict:
        """
        Build weights for the train period and evaluate against realized returns.
        Returns metrics dict.
        """
        weights_train = self.build_weights_strategy(
            pred_train, strategy_name=strategy_name, returns_history=returns_proxy
        )
        w_cols = self.weight_cols
        r_cols = self.asset_cols
        merged = r_train[["id", "date"] + r_cols].merge(
            pd.concat([pred_train[["id","date"]] if "id" in pred_train.columns else pd.DataFrame(),
                       weights_train], axis=1)
            if "id" in pred_train.columns else
            weights_train.assign(
                id   = r_train["id"].values[:len(weights_train)],
                date = r_train["date"].values[:len(weights_train)],
            ),
            on=["id", "date"], how="inner"
        ) if "id" in pred_train.columns else None

        # Simpler approach: align by position (train predictions align 1-to-1 with r_train)
        n = min(len(weights_train), len(r_train))
        W = weights_train.values[:n]
        R = r_train[r_cols].values[:n]
        port_ret = (W * R).sum(axis=1)

        metrics = log_metrics(strategy_name, port_ret)
        return metrics

    def select_best_strategy(
        self,
        pred_train: pd.DataFrame,
        r_train: pd.DataFrame,
        returns_proxy: np.ndarray,
    ) -> str:
        """
        Evaluate all 3 strategies on training data.
        Select the one maximising: Score = CumReturn - 0.5·DD + 0.3·Sharpe
        """
        log("MULTI-STRATEGY EVALUATION", "SECTION")
        scores = {}
        for name in STRATEGY_CONFIGS:
            log(f"\n  Evaluating strategy: [{name.upper()}]", "STRAT")
            metrics        = self.evaluate_strategy_on_train(
                name, pred_train, r_train, returns_proxy
            )
            scores[name]   = metrics["selection_score"]

        log("\n  ── SELECTION SCORES ──", "STRAT")
        for name, sc in sorted(scores.items(), key=lambda x: -x[1]):
            log(f"  {name:15s} → Score = {sc:.4f}", "STRAT")

        best = max(scores, key=scores.__getitem__)
        log(f"\n  🏆  SELECTED STRATEGY: [{best.upper()}]  "
            f"(Score = {scores[best]:.4f})", "STRAT")
        return best

    # ── Build Submission ──────────────────────────────────────────────────────

    def build_submission(
        self,
        x_train: pd.DataFrame,
        x_test: pd.DataFrame,
        r_train: pd.DataFrame | None = None,
    ) -> pd.DataFrame:
        log("BUILDING SUBMISSION", "SECTION")

        # Predictions for train + test
        pred_train = self.predict_returns(x_train)
        pred_test  = self.predict_returns(x_test)
        pred_all   = pd.concat([pred_train, pred_test], axis=0).reset_index(drop=True)

        # Use train predictions as returns proxy for vol / covariance estimation
        returns_proxy = pred_train.values

        # ── Auto-select best strategy (if r_train available)
        if r_train is not None:
            # Align r_train to the same rows as pred_train
            r_train_aligned = r_train.sort_values("date").reset_index(drop=True)
            n = min(len(pred_train), len(r_train_aligned))
            best_strategy = self.select_best_strategy(
                pred_train.iloc[:n].reset_index(drop=True),
                r_train_aligned.iloc[:n].reset_index(drop=True),
                returns_proxy[:n],
            )
        else:
            log("No r_train provided — defaulting to 'hybrid' strategy", "WARN")
            best_strategy = "hybrid"

        # ── Build weights for the full dataset (train + test) using best strategy
        log(f"\nBuilding final weights with [{best_strategy.upper()}] strategy...", "OK")

        # For the test portion, extend returns_proxy with test predictions
        returns_proxy_all = pred_all.values
        weights_all = self.build_weights_strategy(
            pred_all,
            strategy_name=best_strategy,
            returns_history=returns_proxy_all,
        )

        index_all = pd.concat(
            [x_train[["id","date"]].copy(), x_test[["id","date"]].copy()], axis=0
        ).reset_index(drop=True)

        submission = pd.concat([index_all, pred_all, weights_all], axis=1).fillna(0.0)
        log(f"Submission shape: {submission.shape}", "OK")
        log(f"Weight L1 max: "
            f"{submission[self.weight_cols].abs().sum(axis=1).max():.4f}", "OK")
        return submission

    # ── Evaluate on Train ─────────────────────────────────────────────────────

    def evaluate_on_train(
        self,
        submission: pd.DataFrame,
        r_train: pd.DataFrame,
    ) -> dict:
        log("FINAL EVALUATION REPORT", "SECTION")
        scorer     = self.create_scorer()
        mse_report = scorer.score_predictions(submission, r_train)
        log(f"Overall MSE={mse_report['mse']:.6f}  n_rows={mse_report['n_rows']}", "OK")

        w_cols = self.weight_cols
        r_cols = self.asset_cols
        merged = r_train[["id", "date"] + r_cols].merge(
            submission[["id", "date"] + w_cols], on=["id","date"], how="inner"
        )
        if merged.empty:
            log("No overlap for portfolio evaluation.", "WARN")
            return mse_report

        W        = merged[w_cols].values
        R        = merged[r_cols].values
        port_ret = (W * R).sum(axis=1)

        metrics  = log_metrics("FINAL SUBMISSION", port_ret)

        log("\nPer-asset Sharpe (weight × return):")
        for asset, wcol in zip(r_cols, w_cols):
            if asset in merged.columns and wcol in merged.columns:
                pnl_a = merged[wcol].values * merged[asset].values
                log(f"  {asset:12s}: Sharpe={sharpe(pnl_a):.3f}")

        return {**mse_report, **metrics}

    # ── Save / Score ──────────────────────────────────────────────────────────

    def save_submission(
        self, submission: pd.DataFrame, path: str = "submission.parquet"
    ) -> Path:
        path = Path(path)
        submission.to_parquet(path, index=False)
        log(f"Saved → {path}", "OK")
        return path

    def create_scorer(self) -> SubmissionScorerTemplate:
        scorer = SubmissionScorerTemplate()
        scorer.set_assets(self.asset_cols)
        return scorer

    def fit_predict_save(
        self,
        data_dir: str = "data",
        output_path: str = "submission.parquet",
    ) -> pd.DataFrame:
        log("LOADING DATA", "SECTION")
        data = self.load_data(data_dir)
        log("FITTING MODELS", "SECTION")
        self.fit(data["X_train"], data["R_train"])
        submission = self.build_submission(
            data["X_train"], data["X_test"], r_train=data["R_train"]
        )
        scorer = self.create_scorer()
        scorer.validate_submission_format(submission)
        log("Submission validated ✓", "OK")
        self.save_submission(submission, output_path)
        return submission


# ─────────────────────────────────────────────────────────────────────────────
# 11. MAIN
# ─────────────────────────────────────────────────────────────────────────────

def main():
    log("AGGRESSIVE QUANTITATIVE PORTFOLIO — PnL MAXIMISATION EDITION", "SECTION")
    log("Strategies: Conservative | Aggressive | Hybrid → Auto-selected")
    log("Objective : Score = CumReturn - 0.5·MaxDrawdown + 0.3·Sharpe\n")

    model = PortfolioChallengeModel()

    # ── Full pipeline
    data = model.load_data(data_dir="data")

    log("FITTING BASE MODELS", "SECTION")
    model.fit(data["X_train"], data["R_train"])

    # ── Build submission (includes strategy selection on train)
    submission = model.build_submission(
        data["X_train"], data["X_test"], r_train=data["R_train"]
    )

    # ── Full evaluation on training data
    model.evaluate_on_train(submission, data["R_train"])

    # ── Validate format
    scorer = model.create_scorer()
    scorer.validate_submission_format(submission)
    log("Format validation passed ✓", "OK")

    # ── Save
    out = model.save_submission(submission, "submission.parquet")
    log(f"\n🏆  Final submission saved: {out}", "OK")
    log(f"    Columns  : {list(submission.columns[:6])} ... ({len(submission.columns)} total)")
    log(f"    Rows     : {len(submission)}")
    log(f"    Weight L1 max: "
        f"{submission[model.weight_cols].abs().sum(axis=1).max():.4f} (≤1 required)")


if __name__ == "__main__":
    main()

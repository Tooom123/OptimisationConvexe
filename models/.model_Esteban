def log(msg: str, level: str = "INFO") -> None:
    prefix = {
        "INFO":    "ℹ️ ",
        "OK":      "✅",
        "WARN":    "⚠️ ",
        "SECTION": "\n" + "═" * 70 + "\n  ",
        "METRIC":  "📊",
        "STRAT":   "🎯",
    }
    print(f"{prefix.get(level, '')} {msg}")


def sharpe(returns: np.ndarray, eps: float = 1e-8) -> float:
    """Annualised Sharpe (252 trading periods)."""
    if len(returns) < 2:
        return 0.0
    mu    = np.mean(returns)
    sigma = np.std(returns, ddof=1)
    return float(mu / (sigma + eps) * np.sqrt(252))


def rolling_sharpe_std(returns: np.ndarray, window: int = 63) -> float:
    """Std of rolling Sharpe — penalises instability."""
    if len(returns) < window + 1:
        return 0.0
    vals = [sharpe(returns[i - window: i]) for i in range(window, len(returns))]
    return float(np.std(vals)) if vals else 0.0


def compute_metrics(returns: np.ndarray) -> dict:
    """
    Full performance metrics for a return series.
    Returns: Sharpe, CumulativeReturn, Volatility, MaxDrawdown, CalmarRatio
    """
    if len(returns) < 2:
        return {"sharpe": 0.0, "cumulative_return": 0.0,
                "volatility": 0.0, "max_drawdown": 0.0, "calmar": 0.0}

    ann_factor   = np.sqrt(252)
    mu_daily     = np.mean(returns)
    std_daily    = np.std(returns, ddof=1)
    cum_ret      = float(np.sum(returns))                    # arithmetic cumulative
    vol          = float(std_daily * ann_factor)
    sh           = float(mu_daily / (std_daily + 1e-8) * ann_factor)

    # Max Drawdown
    cum_curve    = np.cumsum(returns)
    running_max  = np.maximum.accumulate(cum_curve)
    drawdowns    = running_max - cum_curve
    max_dd       = float(np.max(drawdowns)) if len(drawdowns) > 0 else 0.0

    calmar       = float(cum_ret / (max_dd + 1e-8))

    return {
        "sharpe":            sh,
        "cumulative_return": cum_ret,
        "volatility":        vol,
        "max_drawdown":      max_dd,
        "calmar":            calmar,
    }


def selection_score(
    returns: np.ndarray,
    lam: float = 0.5,
    gamma: float = 0.3
) -> float:
    """
    Score = CumulativeReturn - λ × MaxDrawdown + γ × Sharpe
    Primary: PnL. Penalty: Drawdown. Bonus: Sharpe stability.
    """
    m = compute_metrics(returns)
    return (m["cumulative_return"]
            - lam   * m["max_drawdown"]
            + gamma * m["sharpe"])


def log_metrics(name: str, returns: np.ndarray) -> dict:
    m = compute_metrics(returns)
    sc = selection_score(returns)
    log(f"{'─'*60}", "METRIC")
    log(f"Strategy : {name}", "METRIC")
    log(f"  Sharpe            = {m['sharpe']:.4f}", "METRIC")
    log(f"  Cumulative Return = {m['cumulative_return']:.4f}", "METRIC")
    log(f"  Volatility (ann)  = {m['volatility']:.4f}", "METRIC")
    log(f"  Max Drawdown      = {m['max_drawdown']:.4f}", "METRIC")
    log(f"  Calmar Ratio      = {m['calmar']:.4f}", "METRIC")
    log(f"  Selection Score   = {sc:.4f}  (Return - 0.5·DD + 0.3·Sharpe)", "METRIC")
    return {**m, "selection_score": sc}



# 7.  SCORER (template)
# ─────────────────────────────────────────────────────────────────────────────

class SubmissionScorerTemplate:
    def __init__(self):
        self.asset_cols  = []
        self.pred_cols   = []
        self.weight_cols = []

    def set_assets(self, asset_cols):
        self.asset_cols  = list(asset_cols)
        self.pred_cols   = [f"pred_{c}"   for c in self.asset_cols]
        self.weight_cols = [f"weight_{c}" for c in self.asset_cols]

    def validate_submission_format(self, submission):
        required = ["id", "date"] + self.pred_cols + self.weight_cols
        missing  = [c for c in required if c not in submission.columns]
        if missing:
            raise ValueError(f"Missing columns: {missing}")
        if submission[required].isnull().any().any():
            raise ValueError("NaN values in submission.")
        if submission["id"].duplicated().any():
            raise ValueError("Duplicate ids.")

    def score_predictions(self, predictions, realized_returns):
        common = [c for c in self.asset_cols if c in realized_returns.columns]
        preds  = [f"pred_{c}" for c in common]
        merged = realized_returns[["id", "date"] + common].merge(
            predictions[["id", "date"] + preds], on=["id", "date"], how="inner"
        )
        if merged.empty:
            raise ValueError("No overlap.")
        y_true = merged[common].to_numpy(float)
        y_pred = merged[preds].to_numpy(float)
        return {"mse": float(np.mean((y_true - y_pred) ** 2)),
                "n_rows": int(len(merged))}


# ─────────────────────────────────────────────────────────────────────────────
# 8.  MAIN MODEL
# ─────────────────────────────────────────────────────────────────────────────

class PortfolioChallengeModel:
    """
    v2  —  Anti-overfitting, conservative, OOS-focused.

    Key changes vs v1:
      • Lean feature engineering  (~60 feats vs 391)
      • Walk-forward Ridge only    (no MLP, no GBM)
      • Alpha selected by OOS Sharpe via 5-fold time-series CV
      • Prediction calibration     (CS z-score + 70% shrink)
      • Asset policy multipliers   (asset7=0, assets2,6=0.1)
      • Volatility targeting       (0.5% daily)
      • EMA weight smoothing       (turnover penalty)
      • Strict L1 enforcement
    """

    SHRINKAGE       = 0.70    # prediction shrinkage toward 0
    TARGET_VOL      = 0.005   # 0.5% daily vol target
    TURNOVER_ALPHA  = 0.35    # EMA smoothing of weights
    MAX_ASSET_W     = 0.08    # max gross weight per asset

    def __init__(self):
        self.feature_cols   : list = []
        self.asset_cols     : list = []
        self.pred_cols      : list = []
        self.weight_cols    : list = []
        self.feat_eng       : LeanFeatureEngineer | None = None
        self.per_asset_model: dict = {}   # asset → WalkForwardRidge
        self._feat_names    : list = []

    # ──────────────────────────────────────────────────────────────────────
    def read_table(self, path) -> pd.DataFrame:
        p = Path(path)
        if p.suffix.lower() == ".parquet":
            return pd.read_parquet(p)
        raise ValueError(f"Unsupported format: {p}")

    def load_data(self, data_dir: str = "data") -> dict:
        d = Path(data_dir)
        x_train = self.read_table(d / "X_train.parquet")
        r_train = self.read_table(d / "R_train.parquet")
        x_test  = self.read_table(d / "X_test.parquet")
        self.feature_cols  = [c for c in x_train.columns if c not in ("id","date","split")]
        self.asset_cols    = [c for c in r_train.columns if c not in ("id","date","split")]
        self.pred_cols     = [f"pred_{c}"   for c in self.asset_cols]
        self.weight_cols   = [f"weight_{c}" for c in self.asset_cols]
        log(f"Loaded: {len(x_train)} train | {len(x_test)} test | "
            f"{len(self.feature_cols)} feat | {len(self.asset_cols)} assets", "OK")
        return {"X_train": x_train, "R_train": r_train, "X_test": x_test}

    # ──────────────────────────────────────────────────────────────────────
    def _diagnostic_report(self, asset: str, y: np.ndarray,
                            pred: np.ndarray, alpha: float) -> None:
        pnl  = pred * y
        sh   = annualised_sharpe(pnl)
        tc   = temporal_corr(y, pred)
        r2   = r_squared(y, pred)
        mul  = ASSET_WEIGHT_MULTIPLIER.get(asset, 1.0)
        flag = "⛔ ZEROED" if mul == 0 else ("⚠️  DOWN" if mul < 0.5 else "  ")
        log(f"  {asset:12s}  α={alpha:7.1f}  Sharpe={sh:6.2f}  "
            f"corr={tc:+.4f}  R²={r2:+.4f}  alloc_mul={mul:.2f}  {flag}")

    # ──────────────────────────────────────────────────────────────────────
    def fit(self, x_train: pd.DataFrame, r_train: pd.DataFrame) -> None:
        log("PHASE 1 — FEATURE ENGINEERING", "SECTION")

        x_s = x_train.sort_values("date").reset_index(drop=True)
        r_s = r_train.sort_values("date").reset_index(drop=True)

        # align on common ids
        common = set(x_s["id"]) & set(r_s["id"])
        x_s = x_s[x_s["id"].isin(common)].reset_index(drop=True)
        r_s = r_s[r_s["id"].isin(common)].reset_index(drop=True)

        self.feat_eng = LeanFeatureEngineer(self.feature_cols)
        X_eng = self.feat_eng.fit_transform(x_s)
        self._feat_names = list(X_eng.columns)
        log(f"Feature matrix: {X_eng.shape}  (was 391 in v1 — {X_eng.shape[1]} now)", "OK")

        X_arr = X_eng.values.astype(float)

        log("PHASE 2 — PER-ASSET WALK-FORWARD RIDGE (5-FOLD CV)", "SECTION")
        log(f"{'Asset':14s}  {'α':>8s}  {'TrainSh':>8s}  {'corr':>7s}  {'R²':>7s}  alloc")

        for asset in self.asset_cols:
            if asset not in r_s.columns:
                continue
            y = r_s[asset].values.astype(float)
            model = WalkForwardRidge(n_folds=5, min_train=max(50, len(X_arr) // 6))
            model.fit(X_arr, y)
            pred_train = model.predict(X_arr)
            self._diagnostic_report(asset, y, pred_train, model.best_alpha_)
            self.per_asset_model[asset] = model

    # ──────────────────────────────────────────────────────────────────────
    def _raw_predictions(self, x_df: pd.DataFrame) -> np.ndarray:
        x_df = x_df.sort_values("date").reset_index(drop=True)
        X_eng = self.feat_eng.transform(x_df)
        X_arr = X_eng.values.astype(float)
        preds = np.zeros((len(x_df), len(self.asset_cols)))
        for i, asset in enumerate(self.asset_cols):
            if asset in self.per_asset_model:
                preds[:, i] = self.per_asset_model[asset].predict(X_arr)
        return preds

    def predict_returns(self, x_df: pd.DataFrame) -> pd.DataFrame:
        preds = self._raw_predictions(x_df)
        x_df_sorted = x_df.sort_values("date").reset_index(drop=True)
        return pd.DataFrame(preds, columns=self.pred_cols, index=x_df_sorted.index)

    # ──────────────────────────────────────────────────────────────────────
    def build_weights(self, pred_df: pd.DataFrame,
                      x_df: pd.DataFrame | None = None) -> pd.DataFrame:
        raw = pred_df.to_numpy(dtype=float)

        # calibrate
        cal = calibrate_predictions(raw, shrinkage=self.SHRINKAGE, cs_normalise=True)

        # portfolio construction
        builder = RobustPortfolioBuilder(
            asset_cols       = self.asset_cols,
            target_daily_vol = self.TARGET_VOL,
            cov_window       = 63,
            cov_shrinkage    = 0.6,
            turnover_alpha   = self.TURNOVER_ALPHA,
            max_gross        = 1.0,
        )
        weights = builder.build(cal)

        return pd.DataFrame(weights, columns=self.weight_cols, index=pred_df.index)

    # ──────────────────────────────────────────────────────────────────────
    def build_submission(self, x_train: pd.DataFrame,
                         x_test: pd.DataFrame) -> pd.DataFrame:
        log("BUILDING SUBMISSION", "SECTION")
        x_train_s = x_train.sort_values("date").reset_index(drop=True)
        x_test_s  = x_test.sort_values("date").reset_index(drop=True)

        pred_train = self.predict_returns(x_train_s)
        pred_test  = self.predict_returns(x_test_s)
        pred_all   = pd.concat([pred_train, pred_test], axis=0).reset_index(drop=True)

        x_all  = pd.concat([x_train_s, x_test_s], axis=0).reset_index(drop=True)
        w_all  = self.build_weights(pred_all, x_all).reset_index(drop=True)

        idx_all = pd.concat(
            [x_train_s[["id","date"]], x_test_s[["id","date"]]], axis=0
        ).reset_index(drop=True)

        sub = pd.concat([idx_all, pred_all, w_all], axis=1).fillna(0.0)
        log(f"Submission: {sub.shape[0]} rows × {sub.shape[1]} cols", "OK")
        return sub

    # ──────────────────────────────────────────────────────────────────────
    def save_submission(self, submission: pd.DataFrame,
                        path: str = "submission.parquet") -> Path:
        p = Path(path)
        submission.to_parquet(p, index=False)
        log(f"Saved → {p}", "OK")
        return p

    # ──────────────────────────────────────────────────────────────────────
    def fit_predict_save(self, data_dir: str = "data",
                         output_path: str = "submission.parquet") -> pd.DataFrame:
        data = self.load_data(data_dir)
        self.fit(data["X_train"], data["R_train"])
        sub  = self.build_submission(data["X_train"], data["X_test"])
        self.create_scorer().validate_submission_format(sub)
        log("Format validation ✓", "OK")
        self.save_submission(sub, output_path)
        return sub

    # ──────────────────────────────────────────────────────────────────────
    def create_scorer(self) -> SubmissionScorerTemplate:
        s = SubmissionScorerTemplate()
        s.set_assets(self.asset_cols)
        return s

    # ──────────────────────────────────────────────────────────────────────
    def full_evaluation(self, submission: pd.DataFrame,
                        r_train: pd.DataFrame) -> dict:
        """Detailed evaluation including per-asset and portfolio Sharpe."""
        log("FULL EVALUATION REPORT", "SECTION")

        w_cols = self.weight_cols
        r_cols = self.asset_cols

        merged = r_train[["id","date"] + r_cols].merge(
            submission[["id","date"] + w_cols], on=["id","date"], how="inner"
        )
        if merged.empty:
            log("No overlap for evaluation.", "WARN")
            return {}

        W = merged[w_cols].values
        R = merged[r_cols].values

        # gross exposure
        gross = np.abs(W).sum(axis=1)
        log(f"Mean gross exposure : {gross.mean():.4f}  (max={gross.max():.4f})")
        log(f"Constraint ok       : {(gross <= 1.001).all()}", "OK")

        port_ret = (W * R).sum(axis=1)
        sh_port  = annualised_sharpe(port_ret)
        sh_std   = rolling_sharpe_std(port_ret)
        cum_ret  = float((1 + port_ret).prod() - 1)

        log(f"\nPortfolio Sharpe (ann.)  = {sh_port:.4f}")
        log(f"Rolling Sharpe Std       = {sh_std:.4f}  (lower = more stable)")
        log(f"Cumulative Return        = {cum_ret*100:.2f}%")
        log(f"Selection Score          = {sh_port - 0.5*sh_std:.4f}")

        log(f"\n{'Asset':14s}  {'Weight':>8s}  {'Sh(asset)':>10s}  {'corr':>7s}")
        pred_cols_sub = [f"pred_{c}" for c in r_cols if f"pred_{c}" in submission.columns]
        merged_p = merged.merge(
            submission[["id","date"] + pred_cols_sub], on=["id","date"], how="inner"
        )
        for asset, wcol in zip(r_cols, w_cols):
            if asset not in merged.columns or wcol not in merged.columns:
                continue
            pnl_a = merged[wcol].values * merged[asset].values
            sh_a  = annualised_sharpe(pnl_a)
            w_avg = merged[wcol].abs().mean()
            pcol  = f"pred_{asset}"
            tc    = temporal_corr(merged[asset].values,
                                  merged_p[pcol].values) if pcol in merged_p else float("nan")
            mul   = ASSET_WEIGHT_MULTIPLIER.get(asset, 1.0)
            flag  = "⛔" if mul == 0 else ("↓" if mul < 0.5 else " ")
            log(f"  {asset:12s}  {w_avg:8.5f}  {sh_a:+10.3f}  {tc:+7.4f}  {flag}")

        return {"sharpe": sh_port, "sharpe_std": sh_std, "cum_ret": cum_ret}


# ─────────────────────────────────────────────────────────────────────────────
# 9.  MAIN
# ─────────────────────────────────────────────────────────────────────────────

def main():
    log("PORTFOLIO CHALLENGE  —  MODEL v2  (Anti-Overfitting)", "SECTION")
    log("Diagnosis: Train Sharpe 18 → Test -0.085 = massive overfit in v1", "WARN")
    log("Fix: lean features + Ridge CV + shrinkage + asset policy + vol target")

    model = PortfolioChallengeModel()
    data  = model.load_data(data_dir="data")

    model.fit(data["X_train"], data["R_train"])
    sub = model.build_submission(data["X_train"], data["X_test"])

    model.full_evaluation(sub, data["R_train"])

    model.create_scorer().validate_submission_format(sub)
    log("Submission format validated ✓", "OK")
    out = model.save_submission(sub, "submission.parquet")

    log(f"\n🏆  Submission → {out}", "OK")
    log(f"    Rows       : {len(sub)}")
    log(f"    Columns    : {len(sub.columns)}")
    max_l1 = sub[model.weight_cols].abs().sum(axis=1).max()
    log(f"    Max |w| L1 : {max_l1:.6f}  (must ≤ 1.0)")


if __name__ == "__main__":
    main()

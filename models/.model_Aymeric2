def log(msg: str, level: str = "INFO") -> None:
    icons = {"INFO": "  ", "OK": "✅", "WARN": "⚠️ ", "ERR": "❌",
             "SECTION": "\n" + "═" * 72 + "\n  "}
    print(f"{icons.get(level, '  ')} {msg}")


# ─────────────────────────────────────────────────────────────────────────────
# 1.  METRICS
# ─────────────────────────────────────────────────────────────────────────────

def annualised_sharpe(returns: np.ndarray, eps: float = 1e-9) -> float:
    if len(returns) < 5:
        return 0.0
    mu = np.nanmean(returns)
    sd = np.nanstd(returns, ddof=1)
    return float(mu / (sd + eps) * np.sqrt(252))


def rolling_sharpe_std(returns: np.ndarray, window: int = 42) -> float:
    vals = [annualised_sharpe(returns[max(0, i-window):i])
            for i in range(window, len(returns))]
    return float(np.std(vals)) if vals else 0.0


def temporal_corr(y_true: np.ndarray, y_pred: np.ndarray) -> float:
    if len(y_true) < 5:
        return 0.0
    mask = np.isfinite(y_true) & np.isfinite(y_pred)
    if mask.sum() < 5:
        return 0.0
    return float(np.corrcoef(y_true[mask], y_pred[mask])[0, 1])


def r_squared(y_true: np.ndarray, y_pred: np.ndarray) -> float:
    ss_res = np.sum((y_true - y_pred) ** 2)
    ss_tot = np.sum((y_true - np.mean(y_true)) ** 2)
    return float(1 - ss_res / (ss_tot + 1e-12))


# ─────────────────────────────────────────────────────────────────────────────
# 2.  LEAN FEATURE ENGINEERING  (deliberately simple to prevent overfitting)
# ─────────────────────────────────────────────────────────────────────────────

class LeanFeatureEngineer:
    """
    Minimal feature set:
      - raw features (winsorised)
      - lag-1, lag-5
      - rolling mean 5, 21  |  rolling std 5, 21
      - cross-sectional mean + its lag-1 + sign
      - rolling z-score 21
    Total: ~5 × n_feat features (vs 391 in v1 → massive reduction)
    """

    def __init__(self, feature_cols: list):
        self.feature_cols = feature_cols
        self._clip_lo: dict = {}
        self._clip_hi: dict = {}
        self._global_mean: np.ndarray | None = None
        self._global_std:  np.ndarray | None = None

    def fit(self, x_df: pd.DataFrame) -> None:
        for col in self.feature_cols:
            v = x_df[col].dropna().values
            self._clip_lo[col] = float(np.percentile(v, 2))
            self._clip_hi[col] = float(np.percentile(v, 98))

    def _winsorise(self, df: pd.DataFrame) -> pd.DataFrame:
        out = df[self.feature_cols].copy()
        for col in self.feature_cols:
            out[col] = out[col].clip(self._clip_lo[col], self._clip_hi[col])
        return out

    def transform(self, x_df: pd.DataFrame) -> pd.DataFrame:
        df = x_df.copy().sort_values("date").reset_index(drop=True)
        raw = self._winsorise(df)
        feats = {}

        for col in self.feature_cols:
            s = raw[col]
            feats[col]                = s.values
            feats[f"{col}_lag1"]      = s.shift(1).values
            feats[f"{col}_lag5"]      = s.shift(5).values
            feats[f"{col}_rmean5"]    = s.rolling(5,  min_periods=1).mean().values
            feats[f"{col}_rmean21"]   = s.rolling(21, min_periods=1).mean().values
            feats[f"{col}_rstd5"]     = s.rolling(5,  min_periods=2).std().fillna(0).values
            feats[f"{col}_rstd21"]    = s.rolling(21, min_periods=2).std().fillna(0).values
            mu21   = s.rolling(21, min_periods=1).mean()
            sd21   = s.rolling(21, min_periods=2).std().replace(0, 1e-8).fillna(1e-8)
            feats[f"{col}_zscore21"]  = ((s - mu21) / sd21).values

        # cross-sectional mean (key signal for assets 7/8)
        xbar = raw[self.feature_cols].mean(axis=1)
        feats["xbar"]           = xbar.values
        feats["xbar_lag1"]      = xbar.shift(1).values
        feats["xbar_sign"]      = np.sign(xbar.values)
        feats["xbar_abs"]       = xbar.abs().values
        feats["xbar_rmean21"]   = xbar.rolling(21, min_periods=1).mean().values
        feats["xbar_rstd21"]    = xbar.rolling(21, min_periods=2).std().fillna(0).values
        # threshold features for asset 9
        for thr in [0.3, 0.6]:
            feats[f"xbar_gt_{thr}"]  = (xbar >  thr).astype(float).values
            feats[f"xbar_lt_{thr}"] = (xbar < -thr).astype(float).values

        result = pd.DataFrame(feats, index=df.index)
        result = result.fillna(0).replace([np.inf, -np.inf], 0)
        return result

    def fit_transform(self, x_df: pd.DataFrame) -> pd.DataFrame:
        self.fit(x_df)
        return self.transform(x_df)


# ─────────────────────────────────────────────────────────────────────────────
# 3.  WALK-FORWARD RIDGE  (alpha selected per asset via CV)
# ─────────────────────────────────────────────────────────────────────────────

ALPHA_GRID = [0.01, 0.1, 1.0, 10.0, 100.0, 1000.0, 5000.0]

class WalkForwardRidge:
    """
    Selects Ridge alpha via walk-forward cross-validation (temporal splits).
    Optimises OOS Sharpe (not MSE) to match the actual objective.
    """

    def __init__(self, n_folds: int = 5, min_train: int = 100):
        self.n_folds   = n_folds
        self.min_train = min_train
        self.best_alpha_: float = 1.0
        self._coef:  np.ndarray | None = None
        self._bias:  float = 0.0
        self._feat_mean: np.ndarray | None = None
        self._feat_std:  np.ndarray | None = None

    def _ridge_fit(self, X: np.ndarray, y: np.ndarray, alpha: float):
        n, p = X.shape
        Xb   = np.c_[np.ones(n), X]
        A    = Xb.T @ Xb + alpha * np.eye(p + 1)
        A[0, 0] -= alpha           # don't penalise bias
        try:
            coef = np.linalg.solve(A, Xb.T @ y)
        except np.linalg.LinAlgError:
            coef = np.linalg.lstsq(A, Xb.T @ y, rcond=None)[0]
        return coef[0], coef[1:]   # bias, weights

    def _ridge_predict(self, X: np.ndarray, bias: float,
                       coef: np.ndarray) -> np.ndarray:
        return X @ coef + bias

    def _cv_score(self, X: np.ndarray, y: np.ndarray, alpha: float) -> float:
        n     = len(X)
        fold  = (n - self.min_train) // self.n_folds
        if fold < 20:
            return -np.inf
        sharpes = []
        for k in range(self.n_folds):
            train_end = self.min_train + k * fold
            val_end   = min(train_end + fold, n)
            if val_end - train_end < 10:
                continue
            Xtr, ytr = X[:train_end],       y[:train_end]
            Xvl, yvl = X[train_end:val_end], y[train_end:val_end]
            bias, coef = self._ridge_fit(Xtr, ytr, alpha)
            pred  = self._ridge_predict(Xvl, bias, coef)
            pnl   = pred * yvl
            sharpes.append(annualised_sharpe(pnl))
        return float(np.mean(sharpes)) if sharpes else -np.inf

    def fit(self, X: np.ndarray, y: np.ndarray) -> "WalkForwardRidge":
        # standardise
        self._feat_mean = X.mean(axis=0)
        self._feat_std  = X.std(axis=0) + 1e-8
        Xs = (X - self._feat_mean) / self._feat_std

        best_score, best_alpha = -np.inf, ALPHA_GRID[len(ALPHA_GRID) // 2]
        for alpha in ALPHA_GRID:
            sc = self._cv_score(Xs, y, alpha)
            if sc > best_score:
                best_score = sc
                best_alpha = alpha
        self.best_alpha_ = best_alpha
        # fit on full training data
        self._bias, self._coef = self._ridge_fit(Xs, y, best_alpha)
        return self

    def predict(self, X: np.ndarray) -> np.ndarray:
        Xs = (X - self._feat_mean) / self._feat_std
        return self._ridge_predict(Xs, self._bias, self._coef)


# ─────────────────────────────────────────────────────────────────────────────
# 4.  PREDICTION CALIBRATION
# ─────────────────────────────────────────────────────────────────────────────

def calibrate_predictions(preds: np.ndarray,
                           shrinkage: float = 0.70,
                           cs_normalise: bool = True) -> np.ndarray:
    """
    1. Cross-sectional z-score (remove common factor bias)
    2. Shrink toward 0  (reduce noise amplification)
    3. Clip extremes
    """
    out = preds.copy()

    if cs_normalise and out.shape[1] > 1:
        mu  = out.mean(axis=1, keepdims=True)
        sd  = out.std(axis=1,  keepdims=True) + 1e-10
        out = (out - mu) / sd          # unit cross-sectional variance

    out *= (1.0 - shrinkage)           # shrink toward 0
    out  = np.clip(out, -3.0, 3.0)    # clip extreme z-scores
    return out


# ─────────────────────────────────────────────────────────────────────────────
# 5.  ASSET POLICY  (from empirical results)
# ─────────────────────────────────────────────────────────────────────────────

# Allocation multipliers derived from diagnostics
# asset_7: R²=-0.78 → predictions anti-correlated, ZERO weight
# assets 2,6: temporal_corr ≈ 0.005-0.012, pure noise → minimal
# assets 1,3,5: corr≈0.11 → best signal
# assets 8,9,10,11,12: moderate signal
ASSET_WEIGHT_MULTIPLIER = {
    "asset_1":  1.00,
    "asset_2":  0.10,   # near-zero signal
    "asset_3":  1.00,
    "asset_4":  0.40,   # weak signal
    "asset_5":  1.00,
    "asset_6":  0.10,   # near-zero signal
    "asset_7":  0.00,   # anti-correlated — zero allocation
    "asset_8":  0.80,
    "asset_9":  0.80,
    "asset_10": 0.80,
    "asset_11": 0.60,
    "asset_12": 0.60,
}

# Maximum gross weight per asset
MAX_ASSET_WEIGHT = 0.08        # vs effectively uncapped in v1


# ─────────────────────────────────────────────────────────────────────────────
# 6.  PORTFOLIO CONSTRUCTION
# ─────────────────────────────────────────────────────────────────────────────

class RobustPortfolioBuilder:
    """
    Converts calibrated return predictions → portfolio weights.

    Steps:
      1. Apply asset policy multipliers
      2. Covariance shrinkage (diagonal + identity blend)
      3. Volatility targeting (scale to target daily vol)
      4. Clip per-asset weight
      5. Project onto L1 ball (sum|w|≤1)
      6. Light turnover penalty (smooth via EMA)
    """

    def __init__(self,
                 asset_cols: list,
                 target_daily_vol: float = 0.005,
                 cov_window: int = 63,
                 cov_shrinkage: float = 0.5,
                 turnover_alpha: float = 0.3,
                 max_gross: float = 1.0):
        self.asset_cols       = asset_cols
        self.target_daily_vol = target_daily_vol
        self.cov_window       = cov_window
        self.cov_shrinkage    = cov_shrinkage
        self.turnover_alpha   = turnover_alpha   # EMA for smoothing
        self.max_gross        = max_gross
        self._prev_w          = None

    def _shrunk_cov(self, recent_preds: np.ndarray) -> np.ndarray:
        n = recent_preds.shape[1]
        if recent_preds.shape[0] < 5:
            return np.eye(n)
        S   = np.cov(recent_preds.T, ddof=1)
        mu  = np.trace(S) / n
        rho = self.cov_shrinkage
        return (1 - rho) * S + rho * mu * np.eye(n)

    def build(self, calibrated_preds: np.ndarray) -> np.ndarray:
        T, n = calibrated_preds.shape
        weights = np.zeros((T, n))
        self._prev_w = np.zeros(n)

        for t in range(T):
            mu = calibrated_preds[t].copy()

            # ── apply asset policy multipliers
            for i, asset in enumerate(self.asset_cols):
                mul = ASSET_WEIGHT_MULTIPLIER.get(asset, 1.0)
                mu[i] *= mul

            # ── rough MV weight: w ∝ Σ⁻¹ μ  (diagonal approx for speed)
            window = calibrated_preds[max(0, t - self.cov_window): t]
            if len(window) >= 10:
                Sigma = self._shrunk_cov(window)
                diag_vol = np.sqrt(np.diag(Sigma)) + 1e-8
            else:
                diag_vol = np.ones(n)

            w = mu / (diag_vol ** 2 + 1e-8)

            # ── clip per-asset
            w = np.clip(w, -MAX_ASSET_WEIGHT, MAX_ASSET_WEIGHT)

            # ── volatility targeting
            port_var = float(w @ np.diag(diag_vol ** 2) @ w) if len(window) >= 10 else (w ** 2).sum()
            port_vol = np.sqrt(max(port_var, 1e-10))
            if port_vol > 1e-8:
                scale = self.target_daily_vol / port_vol
                scale = min(scale, 5.0)   # safety cap
                w *= scale

            # ── turnover penalty: smooth via EMA with previous weights
            w = self.turnover_alpha * w + (1 - self.turnover_alpha) * self._prev_w
            self._prev_w = w.copy()

            # ── enforce L1 constraint (sum|w|≤1)
            gross = np.abs(w).sum()
            if gross > self.max_gross:
                w = w / gross * self.max_gross

            weights[t] = w

        return weights


